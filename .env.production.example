# Neon PostgreSQL
# 在 https://console.neon.tech 建立專案後複製
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/paxis?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/paxis?sslmode=require&pgbouncer=false"

# NextAuth
# 產生方式：openssl rand -base64 32
NEXTAUTH_SECRET="your-production-secret"
NEXTAUTH_URL="https://paxis.pages.dev"

# Patisco 介接（選用）
PATISCO_API_URL="https://api.patisco.com"
PATISCO_API_KEY="your-api-key"
PATISCO_WEBHOOK_SECRET="your-webhook-secret"
