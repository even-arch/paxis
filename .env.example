# ==========================================
# SaaS 架構環境變數
# ==========================================

# Admin DB（中央帳號管理，獨立 Neon project）
# 用途：存放所有租戶帳號、狀態、DB URL 對應關係
ADMIN_DATABASE_URL="postgresql://..."

# 租戶 DB（開發時用，正式環境由 Admin DB 動態取得）
# 本機開發時可以直接填一個租戶的 DB URL 做測試
DATABASE_URL="postgresql://..."

# NextAuth
NEXTAUTH_SECRET="change-this-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Neon Management API（Provisioning 腳本用）
# 在 Neon Console → Account → API Keys 取得
NEON_API_KEY=""
NEON_PROJECT_ID=""    # 租戶 DB 要建在哪個 project 下

# Patisco 介接（選用，不填也能獨立運作）
PATISCO_API_URL=""
PATISCO_API_KEY=""
PATISCO_WEBHOOK_SECRET=""
