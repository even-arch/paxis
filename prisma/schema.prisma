// PAXIS — Point Asia eXchange & Inventory System
// Prisma Schema
// 單租戶設計，不需要 TenantID

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 系統設定 (SYS_)
// =============================================================================

model SYS_PatiscoConfig {
  id             Int      @id @default(autoincrement())
  mcpUrl         String   @default("https://mcp.patisco.com")

  // 模式 1：帳密（選填，有填才能自動 refresh JWT）
  username       String?
  encryptedPass  String?  // AES-256-GCM 加密

  // 模式 2：直接貼 Token（選填，JWT 到期需手動更新）
  encryptedJwt   String?  // AES-256-GCM 加密，JWT 有時效
  apiKey         String?  // Patisco API Key（長效，UUID 格式）
  userId         String?  // Patisco userId（供顯示用）
  jwtExpiresAt   DateTime?

  webhookSecret  String?  // Webhook HMAC 簽名驗證密鑰
  cronSecret     String?  // Cron 安全驗證密鑰
  isActive       Boolean  @default(true)
  syncEnabled    Boolean  @default(true)  // false = 暫停從 Patisco MCP Server 撈資料（不影響 webhook 接收）
  lastTestedAt   DateTime?
  lastTestStatus String?  // 'ok' | 'error'
  lastTestMsg    String?
  updatedAt      DateTime @updatedAt

  @@map("SYS_PatiscoConfig")
}

// Patisco 同步作業（每次 full sync 一筆，追蹤進度與回滾）
// status: pending | running | completed | cancelled | error
model SYS_SyncJob {
  id          Int      @id @default(autoincrement())
  status      String   @default("pending")
  trigger     String   // manual | cron | webhook

  // Phase 1 進度
  phase1Total Int      @default(0)   // 預計拉取文件總數
  phase1Done  Int      @default(0)   // 已完成文件數

  // Phase 2 進度（紀錄目前執行到哪個 step，供出錯後 resume）
  phase2Step  String?  // customers | suppliers | products | sls_orders | po_orders | po_supplier_pis | sls_pis | sls_shipments | done

  startedAt   DateTime @default(now())
  completedAt DateTime?
  cancelledAt DateTime?
  errorAt     DateTime?
  errorMsg    String?
  result      Json?    // 完成後統計 { created:{}, updated:{}, skipped:{} }

  performedBy Int?
  performer   SYS_User? @relation(fields: [performedBy], references: [id])

  @@index([status, startedAt])
  @@map("SYS_SyncJob")
}

// Patisco 同步紀錄（去重 + 稽核，Phase 1 raw JSON 存這裡）
// docType: PI | PO | PI_COPY | PO_COPY | DO
// status: ok | error
model SYS_PatiscoSync {
  id                Int      @id @default(autoincrement())
  docType           String   // PI | PO | PI_COPY | PO_COPY | DO
  patiscoDocId      String
  patiscoDocNo      String
  syncedAt          DateTime @default(now())
  source            String   // webhook | cron | manual
  status            String   // ok | error
  result            Json?    // Phase 1 raw JSON { header, products } or { packingList, commercialInvoice }
  analyzedResult    Json?    // Phase 2 解析結果（PAXIS 建立的 record IDs）
  errorMsg          String?

  syncJobId         Int?     // 所屬 sync job ID
  patiscoModifiedAt DateTime? // Patisco 最後異動時間（工程師補上 lastModifiedDate 後可用）

  @@unique([docType, patiscoDocId])
  @@index([syncedAt])
  @@index([syncJobId])
  @@index([docType, status])
  @@map("SYS_PatiscoSync")
}

model SYS_User {
  id          Int    @id @default(autoincrement())
  name        String
  loginId     String    @unique
  password    String
  isEnabled   Boolean   @default(true)
  isSystem    Boolean   @default(false)  // true = 系統內建帳號（Patisco webhook 自動觸發用）
  language    String    @default("zh-TW")
  createdAt   DateTime  @default(now())

  aiProvider      String?
  encryptedAiKey  String?
  aiParseModel    String?

  // Relations
  syncJobs         SYS_SyncJob[]
  purchaseOrders   PO[]
  receipts         PO_Receipt[]
  supplierPIs      PI_SupplierCopy[]
  costSheets       COST_Sheet[]
  passwordResets   SYS_PasswordReset[]
  settingAuditLogs SYS_SettingAuditLog[]
  productHistories PRD_ProductHistory[]
  salesOrders          PO_CustomerCopy[]  @relation("PO_CustomerCopy_creator")
  salesOrdersPerformed PO_CustomerCopy[]  @relation("PO_CustomerCopy_performer")
  salesPIs             PI[]
  shipments        SLS[]
  stockMovements   INV_Movement[]
  invAdjustments   INV_Adjustment[]
  deliveryNotes    SLS_DeliveryNote[]

  @@map("SYS_User")
}

model SYS_SettingAuditLog {
  id          Int      @id @default(autoincrement())
  field       String
  oldValue    String?
  newValue    String?
  reason      String?  @db.Text
  changedBy   Int
  changer     SYS_User @relation(fields: [changedBy], references: [id])
  changedAt   DateTime @default(now())

  @@index([field, changedAt])
  @@map("SYS_SettingAuditLog")
}

model SYS_Company {
  id            Int      @id @default(autoincrement())

  // WAC = 加權平均成本, FIFO = 先進先出, LIFO = 後進先出, SPECIFIC = 個別辨識
  // 變更時必須寫入 SYS_SettingAuditLog
  inventoryMethod String @default("WAC")

  nameZh        String   @default("")
  nameEn        String   @default("")
  shortName     String   @default("")
  addressZh     String   @default("")
  addressEn     String   @default("")
  city          String   @default("")
  countryCode   String   @default("TW")
  phone         String   @default("")
  fax           String   @default("")
  email         String   @default("")
  website       String   @default("")
  taxId         String   @default("")
  bankName      String   @default("")
  bankAccount   String   @default("")
  bankSwift     String   @default("")
  customFields  Json     @default("[]")
  logoBase64    String?  @db.Text
  updatedAt     DateTime @updatedAt

  @@map("SYS_Company")
}

// 公司別名表：記錄文件中出現的公司名稱與其角色
// role: 'SELF' | 'CUSTOMER' | 'SUPPLIER' | 'OTHER'
// 首次匯入遇到未知公司時，停下來問使用者，確認後永久記錄於此，後續自動識別。
model SYS_CompanyAlias {
  id         Int      @id @default(autoincrement())
  alias      String   @unique   // 文件中出現的原始公司名稱
  role       String             // SELF | CUSTOMER | SUPPLIER | OTHER
  customerId Int?
  supplierId Int?
  customer   CUS_Customer? @relation(fields: [customerId], references: [id])
  supplier   SUP_Supplier? @relation(fields: [supplierId], references: [id])
  createdAt  DateTime @default(now())

  @@index([role])
  @@map("SYS_CompanyAlias")
}

model SYS_EmailConfig {
  id              Int      @id @default(autoincrement())
  provider        String   @default("resend")
  encryptedApiKey String?
  fromEmail       String   @default("")
  fromName        String   @default("")
  isActive        Boolean  @default(true)
  lastTestedAt    DateTime?
  lastTestStatus  String?
  lastTestMsg     String?
  updatedAt       DateTime @updatedAt

  @@map("SYS_EmailConfig")
}

model SYS_PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      SYS_User @relation(fields: [userId], references: [id])

  @@map("SYS_PasswordReset")
}

model SYS_Currency {
  code         String   @id
  name         String
  symbol       String
  exchangeRate Decimal
  updatedAt    DateTime @updatedAt

  @@map("SYS_Currency")
}

// 交易條件價格換算規則（公司級設定）
// 例：供應商報 FOR（14）→ 我方對外 FOB（13）→ 需減 2.5%
// adjustmentPct 正值 = 加 %；負值 = 減 %
model SYS_PriceAdjustRule {
  id            Int     @id @default(autoincrement())
  fromTerms     Int     // 進貨條件 Patisco code（14=FOR, 13=FOB…）
  toTerms       Int     // 對外條件 Patisco code（通常 13=FOB）
  adjustmentPct Decimal // e.g. -2.50 = 减 2.5%；+5.00 = 加 5%
  note          String?
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([fromTerms, toTerms])
  @@map("SYS_PriceAdjustRule")
}

model SYS_DataAlert {
  id          Int       @id @default(autoincrement())
  type        String    // PI_CONFLICT | MISSING_PI | UNLINKED_ITEM | WORKFLOW_GAP
  refType     String    // SLS | PI | PO_CustomerCopy
  refId       Int?
  refNo       String?
  message     String
  detail      Json?
  resolvedAt  DateTime?
  resolvedBy  Int?
  syncJobId   Int?
  createdAt   DateTime  @default(now())

  @@map("SYS_DataAlert")
}

// =============================================================================
// 商品管理 (PRD_)
// =============================================================================

model PRD_Product {
  id            Int    @id @default(autoincrement())
  name          String    // Patisco 匯入時暫用 SKU 填代，nameNeedsAI=true 代表待 AI 從規格產生正式品名
  nameNeedsAI   Boolean   @default(false)
  sku           String?   @unique
  modelNo       String?
  description   String?
  specification String?

  unitPerInner  Int?
  unitPerCarton Int?
  cbm           Decimal?
  grossWeight   Decimal?
  netWeight     Decimal?
  length        Decimal?
  width         Decimal?
  height        Decimal?

  htsCode         String?
  countryOfOrigin String?
  unit            String?

  isMadeToOrder Boolean  @default(false)
  safetyStock   Int      @default(0)

  patiscoProductId String?

  sellingPrice      Decimal?
  isAvailableForPos Boolean  @default(false)
  posProductId      String?

  isActive      Boolean   @default(true)
  isArchived    Boolean   @default(false)
  syncJobId     Int?      // Patisco sync job ID，用於回滾
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  supplierProducts  SUP_SupplierProduct[]
  customerProducts  CUS_CustomerProduct[]
  inventoryItems    INV_Stock[]
  purchaseItems     PO_Item[]
  salesItems        PO_CustomerCopy_Item[]
  piItems           PI_Item[]
  costSheets        COST_Sheet[]
  categories        PRD_CategoryMapping[]
  history           PRD_ProductHistory[]
  mktSkuMappings    MKT_SkuMapping[]
  invMovements      INV_Movement[]
  invAdjustments    INV_Adjustment[]
  deliveryNoteItems SLS_DeliveryNoteItem[]

  @@index([sku])
  @@index([modelNo])
  @@map("PRD_Product")
}

model PRD_ProductHistory {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     PRD_Product @relation(fields: [productId], references: [id])

  name          String
  sku           String?
  modelNo       String?
  specification String?
  unitPerInner  Int?
  unitPerCarton Int?
  cbm           Decimal?
  grossWeight   Decimal?
  netWeight     Decimal?
  unit          String?
  unitCost      Decimal?
  currency      String?

  // PO_RECEIPT | AI_IMPORT | MANUAL_EDIT
  sourceType  String
  poOrderId   Int?
  poOrderNo   String?

  changedBy   Int
  changer     SYS_User @relation(fields: [changedBy], references: [id])
  createdAt   DateTime @default(now())

  @@index([productId, createdAt])
  @@map("PRD_ProductHistory")
}

model PRD_Category {
  id        Int   @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    PRD_Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  PRD_Category[] @relation("CategoryTree")
  products  PRD_CategoryMapping[]

  @@map("PRD_Category")
}

model PRD_CategoryMapping {
  productId   Int
  categoryId  Int
  product     PRD_Product  @relation(fields: [productId], references: [id])
  category    PRD_Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
  @@map("PRD_CategoryMapping")
}

// =============================================================================
// 供應商管理 (SUP_)
// =============================================================================

model SUP_Supplier {
  id            Int    @id @default(autoincrement())
  name          String
  shortName     String?
  address       String?
  city          String?
  countryCode   String?
  postalCode    String?
  phoneNo       String?
  fax           String?
  email         String?
  contactPerson String?
  taxId         String?
  paymentTerms  String?
  currencyCode  String?
  note          String?

  patiscoSupplierId String?  // 對應 Patisco 供應商 ID（未來開放時使用）

  // 報價原則（Incoterms）：FOB / FOR / EXW / CIF / CFR…
  defaultTradeTerms String?

  isActive      Boolean   @default(true)
  archivedAt    DateTime? // 封存時間；非 null = 已封存，正常查詢排除
  syncJobId     Int?      // Patisco sync job ID，用於回滾
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 付款週期（天數，null 表示未設定）
  paymentCycleDays Int?

  chargeTemplateId  Int?
  chargeTemplate    PRN_ChargeTemplate? @relation(fields: [chargeTemplateId], references: [id])

  products       SUP_SupplierProduct[]
  purchaseOrders PO[]
  contacts       SUP_Contact[]
  payables       FIN_Payable[]
  companyAliases SYS_CompanyAlias[]
  fobAllocations  SLS_FobCostAllocation[]
  paymentVouchers FIN_PaymentVoucher[]

  @@index([name])
  @@map("SUP_Supplier")
}

model SUP_Contact {
  id          Int   @id @default(autoincrement())
  supplierId  Int
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])
  name        String
  title       String?
  phoneNo     String?
  mobile      String?
  email       String?
  isDefault   Boolean  @default(false)

  @@index([supplierId])
  @@map("SUP_Contact")
}

model SUP_SupplierProduct {
  id          Int    @id @default(autoincrement())
  supplierId  Int
  productId   Int
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])
  product     PRD_Product  @relation(fields: [productId], references: [id])

  supplierSku   String?
  unitPrice     Decimal?
  currencyCode  String?
  moq           Int?
  leadTimeDays  Int?
  isPreferred   Boolean   @default(false)
  note          String?
  updatedAt     DateTime  @updatedAt

  @@unique([supplierId, productId])
  @@index([productId])
  @@map("SUP_SupplierProduct")
}

// 客戶-商品關係（從客戶訂單自動推導，記錄這個客人買過哪些 SKU）
model CUS_CustomerProduct {
  id           Int      @id @default(autoincrement())
  customerId   Int
  productId    Int
  customer     CUS_Customer @relation(fields: [customerId], references: [id])
  product      PRD_Product  @relation(fields: [productId], references: [id])

  lastUnitPrice  Decimal?   // 最近一次成交價
  currencyCode   String?
  lastOrderDate  DateTime?  // 最近下單日期
  orderCount     Int        @default(1)  // 累計下單次數
  note           String?
  updatedAt      DateTime   @updatedAt

  @@unique([customerId, productId])
  @@index([productId])
  @@map("CUS_CustomerProduct")
}

// =============================================================================
// 客戶管理 (CUS_)
// PAXIS 的客戶主檔，不直接對應 Patisco BU_Buyer。
// Patisco webhook 帶來的 buyerCompanyId 存在 PO_CustomerCopy.patiscoBuyerId，
// 由人工或自動流程關聯到此主檔。
// =============================================================================

model CUS_Customer {
  id            Int    @id @default(autoincrement())
  name          String
  shortName     String?
  address       String?
  city          String?
  countryCode   String?
  postalCode    String?
  phoneNo       String?
  fax           String?
  email         String?
  contactPerson String?
  taxId         String?
  paymentTerms  String?
  currencyCode  String?
  note          String?

  patiscoBuyerId String?   // 對應 Patisco BS_Company.ID（選填，人工關聯）

  // 報價原則（Incoterms）：FOB / FOR / EXW / CIF / CFR…
  defaultTradeTerms String?

  isActive      Boolean   @default(true)
  archivedAt    DateTime? // 封存時間；非 null = 已封存，正常查詢排除
  syncJobId     Int?      // Patisco sync job ID，用於回滾
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 收款週期（天數，null 表示未設定）
  collectionCycleDays Int?
  shippingMarkTemplate String?  // 麥頭範本，用 {orderNo} 代入訂單號碼

  chargeTemplateId  Int?
  chargeTemplate    PRN_ChargeTemplate? @relation(fields: [chargeTemplateId], references: [id])

  salesOrders       PO_CustomerCopy[]
  salesPIs          PI[]
  shipments         SLS[]
  contacts          CUS_Contact[]
  receivables       FIN_Receivable[]
  deliveryNotes     SLS_DeliveryNote[]
  customerProducts  CUS_CustomerProduct[]
  companyAliases    SYS_CompanyAlias[]
  printDefaults     PRN_CustomerDefault[]

  @@index([name])
  @@map("CUS_Customer")
}

model CUS_Contact {
  id          Int   @id @default(autoincrement())
  customerId  Int
  customer    CUS_Customer @relation(fields: [customerId], references: [id])
  name        String
  title       String?
  phoneNo     String?
  mobile      String?
  email       String?
  isDefault   Boolean  @default(false)

  @@index([customerId])
  @@map("CUS_Contact")
}

// =============================================================================
// 採購單 (PO_)
//
// 採購流程三節點：
//   節點 1：PO      — 我發出訂單正本給供應商（庫存不動）
//   節點 2：PI_SupplierCopy — 收到供應商 PI 副本，確認預計出貨（庫存不動）
//   節點 3：PO_Receipt    — 收到裝箱單/實際到貨，按「入庫」→ quantity++
//
// 注意：quantity++ 發生在節點 3（裝箱單），不是節點 2（PI 副本）。
// =============================================================================

// 採購單狀態
// 0=草稿, 1=已送出, 2=部分到貨, 3=完成, 4=取消
model PO {
  id            Int    @id @default(autoincrement())
  poNo          String    @unique
  supplierId    Int
  supplier      SUP_Supplier @relation(fields: [supplierId], references: [id])

  // ── 交易鏈關聯（核心勾稽欄位）──────────────────────────────────────────
  // 【主要連結】這張採購單是為了哪張我方 PI 而發出的？
  // 貿易商模式：PI 是對客戶的承諾，採購單是對應的進貨動作，兩者直接掛鉤。
  // sourceType=1（接單後採購）時通常填寫；sourceType=0（主動補貨）時為 null。
  slsPiId       Int?
  slsPi         PI? @relation("PI_PO_Link", fields: [slsPiId], references: [id])

  // 【次要連結】客戶原始訂單（副本，僅供參考，不用於財務計算）
  // 一張 PO_CustomerCopy 可以對應多張 PO（拆單給不同供應商時，
  // poNo 會加上後綴：ABC-2025-001-1、ABC-2025-001-2…）
  salesOrderId  Int?
  salesOrder    PO_CustomerCopy? @relation("PO_CustomerCopy_PO_Link", fields: [salesOrderId], references: [id])

  status        Int       @default(0)
  currencyCode  String
  exchangeRate  Decimal
  totalAmount   Decimal?

  // 文件日期（時間軸錨點）：PO 文件上印的日期，與 createdAt（PAXIS 建立時間）區分
  orderDate     DateTime? // PO 文件上的日期（AI 匯入 / 手動填入）

  expectedDate  DateTime? // 預計到貨日
  shippedDate   DateTime? // 供應商實際出貨日（從裝箱單取得）
  arrivedDate   DateTime? // 實際到貨日

  port          String?
  shipVia       String?
  note          String?

  // 報價原則（Incoterms）：覆蓋供應商預設值；FOB = 供應商出廠到港口費用自理，FOR = 我方負擔運到港口費用
  // null 時沿用 SUP_Supplier.defaultTradeTerms
  tradeTerms    String?

  // 採購觸發來源
  // 0 = 主動補貨, 1 = 接單後採購（isMadeToOrder）, 2 = 安全庫存觸發
  sourceType      Int      @default(0)

  patiscoOrderNo    String?
  patiscoOrderId    String?
  patiscoStatus     String?   // Patisco 文件狀態：'0'=Editing, '1'=Confirmed
  patiscoCreatedAt  DateTime? // Patisco 原始建立時間（PO 文件上的 createdDate）

  syncJobId     Int?      // Patisco sync job ID，用於回滾
  createdBy     Int
  creator       SYS_User  @relation(fields: [createdBy], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  archivedAt    DateTime? // 封存時間，非 null = 已封存，正常查詢自動排除

  items         PO_Item[]
  supplierPIs   PI_SupplierCopy[]
  receipts      PO_Receipt[]
  shipments     SLS[]
  payables      FIN_Payable[]  @relation("PO_Payables")

  @@index([supplierId, status])
  @@index([poNo])
  @@index([slsPiId])
  @@index([salesOrderId])
  @@index([archivedAt])
  @@map("PO")
}

model PO_Item {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       PO  @relation(fields: [orderId], references: [id])
  productId   Int
  product     PRD_Product @relation(fields: [productId], references: [id])

  unitPrice   Decimal
  quantity    Int
  receivedQty Int       @default(0)
  unit        String?
  note        String?

  // 品名快照：保留供應商文件原始品名
  productNameSnapshot String?

  receiptItems    PO_ReceiptItem[]
  supplierPIItems PI_SupplierCopy_Item[]

  @@index([orderId])
  @@index([productId])
  @@map("PO_Item")
}

// 節點 2：收到供應商 PI 副本
// 記錄供應商確認的數量與預計出貨日，庫存不動。
model PI_SupplierCopy {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       PO  @relation(fields: [orderId], references: [id])
  piNo        String    // 供應商的 PI 單號

  // 文件日期（時間軸錨點）：供應商 PI 文件上印的日期
  piDate      DateTime? // PI 文件上的發行日期（AI 匯入 / 手動填入）

  estimatedShipDate DateTime? // 供應商 PI 上標註的預計出貨日
  note        String?

  // 交易條件 & PI 層級加收
  tradeTermsCode Int?    // Patisco payment 欄位值（13=FOB, 14=FOR…）
  extraCharges   Json?   // [{name, type, amount}]

  // 操作稽核
  // source: PATISCO | MANUAL | AI_IMPORT
  source      String   @default("MANUAL")
  performedBy Int?     // null = Patisco 自動觸發
  performer   SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  patiscoDocId     String?
  patiscoDocNo     String?
  patiscoCreatedAt DateTime? // Patisco 原始建立時間（createdDate YYYYMMDDHHmmss）
  patiscoStatus    String?   // Patisco 文件狀態：'0'=Editing, '1'=Confirmed
  syncJobId        Int?      // Patisco sync job ID，用於回滾

  items       PI_SupplierCopy_Item[]

  @@index([orderId])
  @@map("PI_SupplierCopy")
}

model PI_SupplierCopy_Item {
  id            Int    @id @default(autoincrement())
  supplierPIId  Int
  supplierPI    PI_SupplierCopy @relation(fields: [supplierPIId], references: [id])
  poItemId      Int
  poItem        PO_Item       @relation(fields: [poItemId], references: [id])

  confirmedQty  Int  // 供應商確認的出貨數量

  @@index([supplierPIId])
  @@map("PI_SupplierCopy_Item")
}

// 節點 3：入庫確認（收到裝箱單 or 直接按入庫）
// 觸發 quantity++，寫 INV_Movement type=1
model PO_Receipt {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       PO  @relation(fields: [orderId], references: [id])
  receiptNo   String

  // 文件日期（時間軸錨點）：裝箱單 / 到貨文件上的日期
  receiptDate DateTime? // 裝箱單上的日期或實際到貨日（AI 匯入 / 手動填入）

  // 操作稽核（必填，記錄是誰在什麼時間按下入庫）
  // source: PATISCO | MANUAL | AI_IMPORT
  source      String   @default("MANUAL")
  performedBy Int?     // null = Patisco 自動觸發
  performer   SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  patiscoDocId  String?
  patiscoDocNo  String?

  note        String?

  items          PO_ReceiptItem[]
  stockMovements INV_Movement[]
  payable        FIN_Payable?

  @@index([orderId])
  @@map("PO_Receipt")
}

model PO_ReceiptItem {
  id          Int     @id @default(autoincrement())
  receiptId   Int
  receipt     PO_Receipt @relation(fields: [receiptId], references: [id])
  poItemId    Int
  poItem      PO_Item    @relation(fields: [poItemId], references: [id])
  quantity    Int

  @@index([receiptId])
  @@map("PO_ReceiptItem")
}

// =============================================================================
// 銷售單 (SLS_)
//
// 銷售流程三節點：
//   節點 1：PO_CustomerCopy    — 收到客戶訂單（庫存不動）
//   節點 2：PI       — 我發出 PI 正本給客戶 → reservedQty++
//   節點 3：SLS — 發出裝箱單/確認出貨 → quantity--, reservedQty--
//
// 三種來源：
//   PATISCO   = Patisco webhook 自動建立
//   MANUAL    = 人工手填
//   AI_IMPORT = 上傳 PDF/Excel，AI 解析後人工確認
// =============================================================================

// 銷售訂單狀態
// 0=草稿, 1=已確認, 2=PI已發出, 3=部分出貨, 4=完成, 5=取消
model PO_CustomerCopy {
  id          Int    @id @default(autoincrement())
  orderNo     String    @unique
  customerId  Int?   // 可能尚未比對到客戶主檔
  customer    CUS_Customer? @relation(fields: [customerId], references: [id])

  status      Int    @default(0)
  currencyCode  String
  exchangeRate  Decimal
  totalAmount   Decimal?

  // 文件日期（時間軸錨點）：客戶 PO 文件上印的日期
  orderDate   DateTime? // 客戶 PO 文件上的日期（AI 匯入 / 手動填入）

  // 客戶期望出貨日（可能為 null，訂單上不一定有）
  customerRequestedShipDate DateTime?
  /** 客戶的採購單號（當從 PI 匯入時補填，用於與客戶文件核對） */
  customerPoNo  String?
  note        String?

  // 操作稽核
  source      String   @default("MANUAL")
  performedBy Int?
  performer   SYS_User? @relation("PO_CustomerCopy_performer", fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  // Patisco 溯源
  patiscoBuyerId   String?    // Patisco buyerCompanyId（webhook 帶來）
  patiscoBuyerName String?   // 買家公司名稱快照
  patiscoDocId     String?
  patiscoDocNo     String?
  patiscoCreatedAt DateTime? // Patisco 原始建立時間（createdDate YYYYMMDDHHmmss）
  patiscoStatus    String?   // Patisco 文件狀態：'0'=Editing, '1'=Confirmed
  syncJobId        Int?      // Patisco sync job ID，用於回滾

  createdBy   Int
  creator     SYS_User  @relation("PO_CustomerCopy_creator", fields: [createdBy], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime? // 封存時間，非 null = 已封存，正常查詢自動排除

  items          PO_CustomerCopy_Item[]
  pis            PI[]
  purchaseOrders PO[]    @relation("PO_CustomerCopy_PO_Link")
  mktOrders      MKT_Order[]
  deliveryNotes  SLS_DeliveryNote[]

  @@index([customerId, status])
  @@index([orderNo])
  @@index([archivedAt])
  @@map("PO_CustomerCopy")
}

model PO_CustomerCopy_Item {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       PO_CustomerCopy   @relation(fields: [orderId], references: [id])
  productId   Int
  product     PRD_Product @relation(fields: [productId], references: [id])

  unitPrice   Decimal
  quantity    Int
  shippedQty  Int    @default(0) // 已出貨數量
  unit        String?
  note        String?
  /** 客戶 PO 上使用的 SKU 代碼（可能與我方 SKU 不同，用於 PO↔PI 核對） */
  customerSkuRef String?

  // 品名快照：保留文件原始品名，避免 PRD_Product.name 日後修改後歷史對不回去
  // Patisco webhook / AI 匯入時填入；手動建立時可留空（從 PRD_Product 取）
  productNameSnapshot String?

  piItems       PI_Item[]
  shipmentItems SLS_Item[]

  @@index([orderId])
  @@index([productId])
  @@map("PO_CustomerCopy_Item")
}

// 節點 2：我發出 PI 正本給客戶
// 觸發 reservedQty++，寫 INV_Movement type=2
model PI {
  id          Int    @id @default(autoincrement())
  orderId     Int?
  order       PO_CustomerCopy? @relation(fields: [orderId], references: [id])
  piNo        String    @unique

  // 當無對應 PO_CustomerCopy 時，直接存 PI 本身的交易方資訊
  customerId   Int?
  customer     CUS_Customer? @relation(fields: [customerId], references: [id])
  currencyCode String?
  totalAmount  Decimal?

  // 文件日期（時間軸錨點）：PI 文件上印的發行日期
  piDate      DateTime? // PI 文件上的日期（AI 匯入 / 手動填入）

  // PI 上標註的預計出貨日（較貼近實際，用於追蹤提醒）
  estimatedShipDate DateTime?
  // Patisco expiredDate（PI 到期日，即 ETD）
  etd               DateTime?

  // 交易條件（Patisco TradingTerm code：13=FOB, 14=FOR…）& PI 層級加收
  tradeTermsCode Int?    // Patisco payment 欄位值
  extraCharges   Json?   // [{name, type, amount}]，對應 Patisco extraCharges

  // 0=有效, 1=已取消
  status      Int    @default(0)
  cancelledAt DateTime?
  cancelReason String?

  // 操作稽核
  source      String   @default("MANUAL")
  performedBy Int?
  performer   SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  patiscoDocId     String?
  patiscoDocNo     String?
  patiscoCreatedAt DateTime? // Patisco 原始建立時間（createdDate YYYYMMDDHHmmss）
  patiscoStatus    String?   // Patisco 文件狀態：'0'=Editing, '1'=Confirmed
  syncJobId        Int?      // Patisco sync job ID，用於回滾

  archivedAt DateTime? // 封存時間；非 null = 已封存

  items          PI_Item[]
  shipmentPIs    SLS_PI_Link[]
  shipmentItems  SLS_Item[]
  stockMovements INV_Movement[]
  deliveryNotes  SLS_DeliveryNote[]
  poOrders       PO[] @relation("PI_PO_Link")

  @@index([orderId])
  @@map("PI")
}

model PI_Item {
  id          Int    @id @default(autoincrement())
  piId        Int
  pi          PI    @relation(fields: [piId], references: [id])
  slsItemId   Int?
  slsItem     PO_CustomerCopy_Item?  @relation(fields: [slsItemId], references: [id])
  productId   Int?
  product     PRD_Product? @relation(fields: [productId], references: [id])

  quantity    Int

  // 品項層級快照（從 Patisco sync 填入，不覆蓋 PRD_Product）
  unitPrice     Decimal?
  unit          String?
  unitPerCarton Int?
  cbm           Decimal?
  grossWeight   Decimal?
  netWeight     Decimal?

  @@index([piId])
  @@map("PI_Item")
}

// 節點 3：出貨確認（發出裝箱單 or 直接按出貨）
// 觸發 quantity--, reservedQty--，寫 INV_Movement type=4
model SLS {
  id          Int    @id @default(autoincrement())

  // 客戶（直接存，不再靠 orderId 間接推導；一張出貨永遠只有一個客戶）
  customerId  Int?
  customer    CUS_Customer? @relation(fields: [customerId], references: [id])

  // 幣別（冗餘存一份，避免跨多 PI/訂單時要額外 join）
  currencyCode String? @default("USD")

  shipmentNo  String    @unique

  // 實際出貨資訊（作為最終 shippedAt 記錄；nullable — Patisco 未提供時可事後補填）
  actualShipDate  DateTime?
  shippingMethod  String?  // SEA | AIR | COURIER
  portOfLoading   String?  // UN/LOCODE，如 TWKHH
  portOfDischarge String?
  trackingNo      String?

  // 操作稽核（必填）
  source      String   @default("MANUAL")
  performedBy Int?
  performer   SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  patiscoDocId  String?
  patiscoDocNo  String?
  syncJobId     Int?    // Patisco sync job ID，用於回滾

  archivedAt DateTime? // 封存時間；非 null = 已封存

  // 採購側連結（回查 DO 對應的 PO，供成本勾稽）
  poOrderId    Int?
  poOrder      PO? @relation(fields: [poOrderId], references: [id])

  // Patisco DO 原始日期（來自 listDeliveryOrders + getDeliveryOrderDetail）
  doCreatedDate   DateTime?  // DO 建立日（Patisco createdDate）
  doExpiredDate   DateTime?  // DO 有效期限（Patisco expiredDate）
  doCompletedDate DateTime?  // DO 完成日（Patisco completedDate，來自清單項目）

  // 出貨文件號（Packing List / Commercial Invoice 上的編號，供核對用）
  packingListNo     String?
  commercialInvNo   String?

  // CI 出貨匯率（開 Commercial Invoice 當下訂定的匯率，用於 FIN_Receivable.rateAtInvoice）
  // 與訂單建立時的匯率不同，出貨日期可能晚數月，匯率已變
  ciExchangeRate    Decimal?

  // CI 附加費（Handling Charge、空運墊款等）
  ciAdditionalChargesForeign  Decimal?  // 附加費總計（外幣，通常 EUR）
  ciExtraCharges              Json?     // [{name, type, amount, charge}] Patisco extraCharges 原始陣列

  note        String?

  // 關聯的 PI 清單（多對多；同一張出貨可包含同一客戶的多張 PI）
  pis            SLS_PI_Link[]
  items          SLS_Item[]
  stockMovements INV_Movement[]
  receivable     FIN_Receivable?
  payables       FIN_Payable[]  @relation("SLS_Payables")
  fobCostItems   SLS_FobCostItem[]

  @@index([customerId])
  @@map("SLS")
}

// SLS ↔ PI 多對多關聯表
// 一張出貨可包含同一客戶的多張 PI，每張 PI 也可能被多次局部出貨
model SLS_PI_Link {
  shipmentId  Int
  shipment    SLS @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  piId        Int
  pi          PI       @relation(fields: [piId], references: [id])

  @@id([shipmentId, piId])
  @@index([piId])
  @@map("SLS_PI_Link")
}

model SLS_Item {
  id            Int    @id @default(autoincrement())
  shipmentId    Int
  shipment      SLS @relation(fields: [shipmentId], references: [id])
  slsItemId     Int?
  slsItem       PO_CustomerCopy_Item?    @relation(fields: [slsItemId], references: [id])
  // 直接記錄來源 PI，方便按 PI 分組顯示（同一 DO 可含多張 PI）
  piId          Int?
  pi            PI?      @relation(fields: [piId], references: [id])

  // Patisco 原始欄位：product 找不到時也不丟資料
  rawSku        String?        // Patisco packing 的 SKU（product 不存在時仍保留）
  rawProductName String?       // Patisco packing 的品名

  quantity      Int

  // 箱號（每張 PI 各自從 1 起算，對應麥頭上的 C/NO.）
  cartons       Int?           // 箱數
  cartonNoFrom  String?        // 起始箱號（如 "1"）
  cartonNoTo    String?        // 結束箱號（如 "10"；與 From 相同則只有一箱）

  // 重量（kg）：淨重 = 貨物本身；毛重 = 含包裝箱
  grossWeightKg Decimal?       // 毛重 kg
  netWeightKg   Decimal?       // 淨重 kg

  // 材積：兩種單位並存，互相換算（1 ft³ = 0.028317 m³）
  // 台灣供應商習慣報 ft³，海關/船公司用 m³，兩者皆存
  cubicFt       Decimal?       // 材積 ft³（Patisco 原始值）
  cbm           Decimal?       // 材積 m³（= cubicFt × 0.028317）

  // 計價資訊（來自 PI_Item，sync 時帶入）
  unit          String?        // 單位（PCS / PAIRS / SETS 等）
  unitPrice     Decimal?       // 單價（幣別同所屬 PI）

  @@index([shipmentId])
  @@index([piId])
  @@map("SLS_Item")
}

// =============================================================================
// 庫存管理 (INV_)
//
// 兩階段庫存模型：
//   quantity     = 實際庫存（倉庫裡真正有的數量）
//   reservedQty  = 預留量（已發 PI 正本給客戶、尚未出倉）
//   availableQty = quantity - reservedQty（前端防超賣用這個，不存 DB）
//
// 五個觸發點（對應文件節點）：
//   入庫：收到裝箱單/按入庫（PO_Receipt）           → quantity++
//   預留：發出 PI 正本給客戶（PI）              → reservedQty++
//   取消預留：PI 正本取消（PI.status=1）        → reservedQty--
//   出倉：發出裝箱單/按出貨（SLS）         → quantity--, reservedQty--
//   手動調整/盤點/POS                              → 依情況
// =============================================================================

model INV_Stock {
  id           Int    @id @default(autoincrement())
  productId    Int    @unique
  product      PRD_Product @relation(fields: [productId], references: [id])

  quantity     Int    @default(0)
  reservedQty  Int    @default(0)
  safetyStock  Int    @default(0)
  // avgUnitCost 移除：成本計算屬於 COST 模組，不在庫存層追蹤
  updatedAt    DateTime @updatedAt

  @@map("INV_Stock")
}

// 庫存調整單（盤點後發現差異時使用）
// 每一筆庫存調整都必須有這張單據作為依據，不允許無單據的自由調整。
// 調整完成後產生一筆 INV_Movement type=5。
model INV_Adjustment {
  id          Int    @id @default(autoincrement())
  adjustNo    String @unique  // 調整單號（系統產生或人工填入）
  productId   Int
  product     PRD_Product @relation(fields: [productId], references: [id])

  reason      String   // 調整原因（必填，e.g. 盤點差異、損壞報廢、樣品出庫）
  beforeQty   Int      // 調整前庫存快照
  afterQty    Int      // 調整後庫存（人工填入，系統計算 delta）
  delta       Int      // afterQty - beforeQty（正數=補入，負數=扣除）

  // 稽核
  performedBy Int
  performer   SYS_User  @relation(fields: [performedBy], references: [id])
  performedAt DateTime  @default(now())
  note        String?

  movement    INV_Movement?

  @@index([productId])
  @@map("INV_Adjustment")
}

// 異動類型：
//   1 = 採購入庫     PO_Receipt 確認（qtyDelta > 0）
//   2 = 預留         PI 發出（reservedDelta > 0）
//   3 = 取消預留     PI 取消（reservedDelta < 0）
//   4 = 出倉         SLS 確認（qtyDelta < 0, reservedDelta < 0）
//   5 = 庫存調整     INV_Adjustment 單據（qtyDelta 可正可負）
//   6 = 系統反轉     刪除出貨/入庫單時自動產生，不需 INV_Adjustment（qtyDelta > 0 = 反轉出貨入庫）
//   8 = POS 銷售出庫 （預留給 POS 對接，qtyDelta < 0）
//   9 = POS 退貨入庫 （預留給 POS 對接，qtyDelta > 0）
//
// qtyDelta / reservedDelta 正負號規則：
//   正數 = 增加，負數 = 減少（直接加到當前數值即得 quantityAfter / reservedAfter）
model INV_Movement {
  id           Int      @id @default(autoincrement())
  productId    Int
  product      PRD_Product @relation(fields: [productId], references: [id])
  type         Int

  qtyDelta        Int        // 正數=增加，負數=減少
  reservedDelta   Int        @default(0)

  // 異動後快照（方便查帳，不需重算）
  quantityAfter   Int
  reservedAfter   Int

  // 操作稽核
  // performedBy = null 時表示 Patisco 自動觸發
  performedBy  Int?
  performer    SYS_User?     @relation(fields: [performedBy], references: [id])
  performedAt  DateTime      @default(now())

  // 來源（PATISCO | MANUAL | AI_IMPORT）
  source       String        @default("MANUAL")

  // 採購側溯源（type=1）
  receiptId    Int?
  receipt      PO_Receipt?   @relation(fields: [receiptId], references: [id])

  // 銷售側溯源（type=2,3,4）
  slsPiId       Int?
  slsPi         PI?       @relation(fields: [slsPiId], references: [id])
  slsShipmentId Int?
  slsShipment   SLS? @relation(fields: [slsShipmentId], references: [id])

  // 庫存調整單溯源（type=5）
  adjustmentId  Int?          @unique
  adjustment    INV_Adjustment? @relation(fields: [adjustmentId], references: [id])

  // Patisco 文件溯源
  patiscoDocType String?
  patiscoDocId   String?
  patiscoDocNo   String?

  note         String?
  createdAt    DateTime @default(now())

  @@index([productId, createdAt])
  @@index([receiptId])
  @@index([slsPiId])
  @@index([slsShipmentId])
  @@index([patiscoDocType, patiscoDocId])
  @@map("INV_Movement")
}

// =============================================================================
// 成本計算 (COST_)
// =============================================================================

model COST_Sheet {
  id            Int    @id @default(autoincrement())
  name          String
  productId     Int
  product       PRD_Product @relation(fields: [productId], references: [id])

  fobPrice      Decimal
  fobCurrency   String
  fobExRate     Decimal

  countryOfOrigin String?
  portOfLoading   String?

  htsCode         String?
  dutyRate        Decimal?
  dutyAmount      Decimal?
  oceanFreight    Decimal?
  insurance       Decimal?
  agentFee        Decimal?
  consolidation   Decimal?
  deconsolidation Decimal?
  userFee         Decimal?
  harborFee       Decimal?
  otherCharge     Decimal?
  otherChargeNote String?

  landedCost      Decimal?
  sellingPrice    Decimal?
  grossMarginPct  Decimal?

  container40ftQty  Int?
  container40ftPcs  Int?

  createdBy     Int
  creator       SYS_User  @relation(fields: [createdBy], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([productId])
  @@map("COST_Sheet")
}

// =============================================================================
// 財務對帳 (FIN_)
//
// FIN_Payable   — 應付帳款，由 PO_Receipt 入庫確認時自動產生
// FIN_Receivable — 應收帳款，由 SLS 出貨確認時自動產生
// =============================================================================

// 付款狀態：0=未付, 1=部分付清, 2=已付清
model FIN_Payable {
  id          Int    @id @default(autoincrement())

  supplierId  Int
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])

  // 來源單據（入庫觸發，舊路徑；貿易商模式不走此路徑）
  receiptId   Int?   @unique
  receipt     PO_Receipt? @relation(fields: [receiptId], references: [id])

  // 出貨觸發（貿易商模式：出貨 → 付供應商）
  shipmentId  Int?
  shipment    SLS?   @relation("SLS_Payables", fields: [shipmentId], references: [id])
  poId        Int?
  po          PO?    @relation("PO_Payables", fields: [poId], references: [id])

  // 基本金額（依採購單品項成本計算，TWD）
  amountTWD   Decimal

  // ── 費用明細（對應「台灣出貨明細表」各項扣除費用，事後填入）────────────────
  customsFeeTWD      Decimal? // 1. 報關費用
  truckingFeeTWD     Decimal? // 2. 拖車費用
  containerFeeTWD    Decimal? // 3. 吊櫃及提單費 / 併櫃費
  bankFeePct         Decimal? // 4. 銀行費用（%，乘以 amountTWD 自動計算）
  portServiceFeeTWD  Decimal? // 5. 商港 & 貿易服務費
  wireTransferFeeTWD Decimal? // 6. 電匯費用
  commissionTWD      Decimal? // 7. 佣金
  otherAdjustmentTWD    Decimal? // 8. 其他調整（正值=加收，負值=扣除；如發票差額）
  otherAdjustmentNote   String?  //    說明（例：「扣除發票多50元」）
  // 計算結果（前端也可即時計算，存下來供報表/查帳用）
  vatPct             Decimal? // 營業稅率（通常 5%）
  finalWireAmountTWD Decimal? // 最終匯款金額 = 實付 + 營業稅
  // ────────────────────────────────────────────────────────────────────────────

  // FOB 費用平攤扣款（由 SLS_FobCostAllocation 計算後寫入，不可手動修改）
  fobCostDeductionTWD Decimal @default(0)  // 累計扣款金額；實付 = amountTWD - fobCostDeductionTWD - 其他費用

  // 到期日（入庫日 + 供應商付款週期）
  dueDate     DateTime?

  // 付款狀態
  status      Int    @default(0)  // 0=未付, 1=部分, 2=已付
  paidAt      DateTime?
  paidAmountTWD Decimal?
  note        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 批次付款：若本筆是跟著另一張一起付的，記錄主單 id
  batchPayableId  Int?
  batchPayable    FIN_Payable?  @relation("PayableBatch", fields: [batchPayableId], references: [id])
  batchMembers    FIN_Payable[] @relation("PayableBatch")

  fobAllocations SLS_FobCostAllocation[]
  voucherItem    FIN_PaymentVoucherItem?

  @@unique([shipmentId, poId])
  @@index([supplierId])
  @@index([dueDate])
  @@index([shipmentId])
  @@map("FIN_Payable")
}

// 收款狀態：0=未收, 1=部分收款, 2=已收清
model FIN_Receivable {
  id          Int    @id @default(autoincrement())

  customerId  Int?
  customer    CUS_Customer? @relation(fields: [customerId], references: [id])
  customerName String?  // 備用，customerId 為 null 時使用

  // 來源單據
  shipmentId  Int    @unique
  shipment    SLS @relation(fields: [shipmentId], references: [id])

  // 金額（原始幣別，通常是 EUR）
  currencyCode    String
  amountForeign   Decimal  // EUR 金額

  // 報帳匯率（PI 開出時的匯率，用於帳面計算）
  rateAtInvoice   Decimal
  amountTWD       Decimal  // = amountForeign × rateAtInvoice

  // 到期日（出貨日 + 客戶收款週期）
  dueDate         DateTime?

  // 收款狀態
  status          Int    @default(0)  // 0=未收, 1=部分, 2=已收
  collectedAt     DateTime?
  collectedForeign Decimal?  // 實際收到的 EUR 金額
  rateAtCollection Decimal?  // 押匯匯率
  collectedTWD    Decimal?   // = collectedForeign × rateAtCollection
  fxGainLoss      Decimal?   // = collectedTWD - (collectedForeign × rateAtInvoice)

  note            String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customerId])
  @@index([dueDate])
  @@map("FIN_Receivable")
}

// =============================================================================
// FOB 費用平攤 (SLS_FobCost*)
// 當一批出貨中有 FOB 供應商時，港前運輸費用（拖車、報關等）須按毛重比例
// 平攤給各 FOB 供應商，並從其應付帳款中扣除。
// FOR 供應商：費用由供應商自理，不參與平攤。
// =============================================================================

// 每張出貨單的物流費用項目（手動輸入）
model SLS_FobCostItem {
  id          Int      @id @default(autoincrement())
  shipmentId  Int
  shipment    SLS @relation(fields: [shipmentId], references: [id])

  name        String   // 費用名目：拖車費、報關費、倉租費…
  amountTWD   Decimal  // 費用金額（TWD）
  note        String?

  allocations SLS_FobCostAllocation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shipmentId])
  @@map("SLS_FobCostItem")
}

// 費用平攤結果：每筆費用分配到各 FOB 供應商的明細
model SLS_FobCostAllocation {
  id          Int      @id @default(autoincrement())
  costItemId  Int
  costItem    SLS_FobCostItem @relation(fields: [costItemId], references: [id])

  supplierId  Int
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])

  poId        Int?     // 對應的 PO（用於追蹤；可 null）

  grossWeightKg Decimal  // 此供應商在本次出貨的毛重（kg）
  weightPct     Decimal  // 佔所有 FOB 供應商總重的百分比（0-100）
  allocatedTWD  Decimal  // 分攤金額 = costItem.amountTWD × weightPct / 100

  // 扣款狀態：false=待套用, true=已寫入 FIN_Payable.fobCostDeductionTWD
  applied     Boolean  @default(false)
  payableId   Int?
  payable     FIN_Payable? @relation(fields: [payableId], references: [id])

  createdAt   DateTime @default(now())

  @@index([costItemId])
  @@index([supplierId])
  @@map("SLS_FobCostAllocation")
}

// =============================================================================
// UPS 出貨提單紀錄 (UPS_)
// 記錄每一張 UPS 提單的完整資訊，包含關聯 PI、提貨預約等。
// =============================================================================

model UPS_ShipmentLog {
  id                   Int      @id @default(autoincrement())

  // UPS 回傳識別碼
  trackingNumber       String
  upsShipmentId        String?  // UPS ShipmentIdentificationNumber

  // 服務
  serviceCode          String
  serviceName          String?

  // 關聯 PI（選填，可能是手動建立未關聯 PI）
  piId                 Int?
  piNo                 String?

  // 地址快照（JSON，避免主檔變更後失去歷史紀錄）
  originSnapshot       Json
  destinationSnapshot  Json

  // 貨物快照
  packagesSnapshot     Json     // Array of { weightKg, dims, items[] }
  declaredValue        Decimal?
  declaredCurrency     String?

  // 費用（UPS 回傳）
  chargedAmount        Decimal?
  chargedCurrency      String?

  // 標籤（Base64）
  labelBase64          String?  @db.Text
  labelFormat          String?  @default("GIF")  // GIF | PNG | PDF

  // 預約提貨
  pickupConfirmationNo String?
  pickupReadyTime      DateTime?   // 可供提貨的最早時間
  pickupCloseTime      DateTime?   // 最晚關門時間
  pickupScheduledDate  DateTime?   // UPS 預約提貨日

  createdAt            DateTime @default(now())
  createdByUserId      Int?

  @@index([trackingNumber])
  @@index([piNo])
  @@index([createdAt])
  @@map("UPS_ShipmentLog")
}

// 系統 Key-Value 設定表（持久化，取代 in-memory system-settings）
model SYS_KeyValue {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("SYS_KeyValue")
}

// =============================================================================
// 電商市場整合 (MKT_)
// 支援 B2C 電商平台（露天、蝦皮等）的訂單同步與庫存管理
// =============================================================================

model MKT_Channel {
  id           Int      @id @default(autoincrement())
  platform     String   // "RUTEN" | "SHOPEE"
  label        String?  // 顯示名稱，e.g. "露天拍賣 Point Asia 店"
  apiKey       String   @db.Text  // 加密儲存
  secretKey    String   @db.Text  // 加密儲存
  saltKey      String   @db.Text  // 加密儲存（露天專用）
  isActive     Boolean  @default(false)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  skuMappings  MKT_SkuMapping[]
  syncLogs     MKT_SyncLog[]
  orders       MKT_Order[]

  @@map("MKT_Channel")
}

model MKT_SkuMapping {
  id           Int      @id @default(autoincrement())
  channelId    Int
  channel      MKT_Channel @relation(fields: [channelId], references: [id])
  platformSku  String   // 露天上的 SKU 或商品代號
  paxisSku     String   // 對應到 PRD_Product.sku
  productId    Int?
  product      PRD_Product? @relation(fields: [productId], references: [id])
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([channelId, platformSku])
  @@map("MKT_SkuMapping")
}

model MKT_SyncLog {
  id           Int      @id @default(autoincrement())
  channelId    Int
  channel      MKT_Channel @relation(fields: [channelId], references: [id])
  action       String   // "webhook_received" | "order_sync" | "ship" | "waybill"
  status       String   // "ok" | "error" | "ignored"
  platformOrderNo String?
  detail       String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([channelId, createdAt])
  @@map("MKT_SyncLog")
}

model MKT_Order {
  id                  Int      @id @default(autoincrement())
  channelId           Int
  channel             MKT_Channel @relation(fields: [channelId], references: [id])
  platformOrderNo     String   // 露天訂單編號
  status              String   // pending | paid | ready_to_ship | shipped | cancelled
  buyerName           String?
  buyerPhone          String?
  buyerAddress        String?
  logisticsCode       String?  // TCAT | SEVEN | SEVEN_COD | FAMI | FAMI_COD | HILIFE | POST | SVB2C | FMB2C | imail
  logisticsTrackingNo String?
  logisticsId         String?  // 露天面單 ID（getshippingid 回傳）
  waybillPrinted      Boolean  @default(false)
  totalAmount         Decimal?
  rawPayload          Json?    // 露天 API 原始資料快照
  slsOrderId          Int?     // 匯入 PAXIS 後關聯的 PO_CustomerCopy
  slsOrder            PO_CustomerCopy? @relation(fields: [slsOrderId], references: [id])
  paidAt              DateTime?
  shippedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  items               MKT_OrderItem[]

  @@unique([channelId, platformOrderNo])
  @@index([channelId, status])
  @@map("MKT_Order")
}

model MKT_OrderItem {
  id           Int      @id @default(autoincrement())
  orderId      Int
  order        MKT_Order @relation(fields: [orderId], references: [id])
  platformSku  String
  paxisSku     String?
  productId    Int?
  itemName     String?
  qty          Int
  unitPrice    Decimal?

  @@map("MKT_OrderItem")
}

// =============================================================================
// 簡易出貨單 (SLS_DeliveryNote)
// 我方出貨給客戶的國內銷貨單，一式三聯（存根/客戶/司機）
// 資料從 PI 或 PO_CustomerCopy 帶入品項
// status: DRAFT → DISPATCHED → RECEIVED
// =============================================================================

model SLS_DeliveryNote {
  id            Int      @id @default(autoincrement())
  docNo         String   @unique               // DN-YYYYMMDD-XXXX
  customerId    Int?
  customer      CUS_Customer?  @relation(fields: [customerId], references: [id])
  slsPiId       Int?
  slsPi         PI?        @relation(fields: [slsPiId], references: [id])
  slsOrderId    Int?
  slsOrder      PO_CustomerCopy?     @relation(fields: [slsOrderId], references: [id])

  issueDate     DateTime
  deliveryDate  DateTime?

  contactName   String?                        // 聯絡人
  contactPhone  String?                        // 電話

  deliveryAddr  String?                        // 送貨地址
  freightCo     String?                        // 貨運行
  vehicleNo     String?                        // 車號

  shippingMark  String?                        // 麥頭
  note          String?                        // 備註
  counterpartNo String?                        // 對方單號（客戶 PO 號）

  status        String   @default("DRAFT")     // DRAFT | DISPATCHED | RECEIVED

  performedBy   Int?
  performer     SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         SLS_DeliveryNoteItem[]

  @@index([customerId])
  @@index([slsPiId])
  @@index([slsOrderId])
  @@map("SLS_DeliveryNote")
}

model SLS_DeliveryNoteItem {
  id             Int      @id @default(autoincrement())
  deliveryNoteId Int
  deliveryNote   SLS_DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  productId      Int?
  product        PRD_Product? @relation(fields: [productId], references: [id])

  description    String?
  quantity       Int      @default(0)
  unit           String?
  cartons        Int?
  grossWeightKg  Decimal?

  @@index([deliveryNoteId])
  @@map("SLS_DeliveryNoteItem")
}

// =============================================================================
// FIN_PaymentVoucher — 付款通知單（PayUni）
// 合併多張應付帳款，產生一份傳給供應商確認的付款文件
// status: DRAFT → SENT → CONFIRMED → PAID
// =============================================================================

model FIN_PaymentVoucher {
  id          Int      @id @default(autoincrement())
  voucherNo   String   @unique  // 流水號，e.g. PV-20260613-0001

  supplierId  Int
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])

  status      String   @default("DRAFT")  // DRAFT | SENT | CONFIRMED | PAID

  vatPct      Decimal  @default(5)         // 營業稅率（%）
  note        String?

  sentAt      DateTime?
  confirmedAt DateTime?
  paidAt      DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       FIN_PaymentVoucherItem[]
  adjustments FIN_PaymentVoucherAdjustment[]

  @@index([supplierId])
  @@index([status])
  @@map("FIN_PaymentVoucher")
}

model FIN_PaymentVoucherItem {
  id         Int      @id @default(autoincrement())

  voucherId  Int
  voucher    FIN_PaymentVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  payableId  Int      @unique  // 一張 Payable 只能進一張 Voucher
  payable    FIN_Payable @relation(fields: [payableId], references: [id])

  amountTWD  Decimal  // 快照：建立時從 FIN_Payable 抄過來，避免事後改動影響

  @@index([voucherId])
  @@map("FIN_PaymentVoucherItem")
}

model FIN_PaymentVoucherAdjustment {
  id         Int      @id @default(autoincrement())

  voucherId  Int
  voucher    FIN_PaymentVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  name       String   // 拖車費、代墊印刷費、FOB 平攤…
  amountTWD  Decimal  // 正數=加收，負數=扣款
  category   String   @default("OTHER")  // LOGISTICS | PASSTHROUGH | FORMULA | TAX | OTHER
  note       String?

  @@index([voucherId])
  @@map("FIN_PaymentVoucherAdjustment")
}

// =============================================================================
// 列印模板 (PRN_)
// 儲存各種單據的 HTML/CSS 列印模板
// docType: "PI" | "PO_ORDER"
// =============================================================================

// 每個客戶每種單據的自由欄位預設值
// docType: "PI" | "PO_ORDER"
model PRN_CustomerDefault {
  id         Int          @id @default(autoincrement())
  customerId Int
  customer   CUS_Customer @relation(fields: [customerId], references: [id])
  docType    String
  freeFields Json         // { portOfLoading, portOfDischarge, ... }
  updatedAt  DateTime     @updatedAt

  @@unique([customerId, docType])
  @@index([customerId])
  @@map("PRN_CustomerDefault")
}

model PRN_Template {
  id          Int      @id @default(autoincrement())
  name        String
  docType     String              // PI | PO_ORDER
  htmlBody    String   @db.Text  // HTML 模板本體，含 {{variable}} 佔位符
  fieldMap    Json                // { "{{pi_no}}": "PI.piNo", ... }
  freeFields  Json                // [{ key, label, defaultValue }]
  isDefault      Boolean  @default(false)
  isSystem       Boolean  @default(false)
  sealPlacements Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([docType])
  @@map("PRN_Template")
}

model SYS_Seal {
  id          Int      @id @default(autoincrement())
  name        String
  imageBase64 String   @db.Text
  createdAt   DateTime @default(now())
  @@map("SYS_Seal")
}

// =============================================================================
// 費用模板 (PRN_ChargeTemplate)
// 可掛在客戶或供應商檔案上，列印時自動帶入附加費用計算
// =============================================================================

model PRN_ChargeTemplate {
  id          Int      @id @default(autoincrement())
  name        String                         // 模板名稱，如「Point Helmig 標準費用」
  description String?
  items       PRN_ChargeTemplateItem[]
  customers   CUS_Customer[]
  suppliers   SUP_Supplier[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("PRN_ChargeTemplate")
}

// calcType: PERCENT（百分比）| FLAT（固定金額）
// calcBase: PRODUCT_SUBTOTAL（商品小計）| GRAND_TOTAL（含前項附加費後的合計）| FLAT（不依基準）
// accountCategory: 對應未來會計科目分類
//   SALES_REVENUE | SERVICE_FEE | TAX_OUTPUT | TAX_INPUT | HANDLING | FREIGHT | OTHER
model PRN_ChargeTemplateItem {
  id              Int                @id @default(autoincrement())
  templateId      Int
  template        PRN_ChargeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name            String             // 費用名稱，如「PLUS HANDLING CHARGE」
  calcType        String             // PERCENT | FLAT
  calcBase        String             // PRODUCT_SUBTOTAL | GRAND_TOTAL | FLAT
  rate            Decimal            // 百分比時為 5.0（表示5%）；固定金額時為金額
  currency        String?            // 固定金額時的幣別（PERCENT 時為 null）
  accountCategory String             // 科目分類
  sortOrder       Int    @default(0)

  @@index([templateId])
  @@map("PRN_ChargeTemplateItem")
}
