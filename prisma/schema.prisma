// PAXIS — Point Asia eXchange & Inventory System
// Prisma Schema
// 單租戶設計，不需要 TenantID

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 系統設定 (SYS_)
// =============================================================================

// Patisco 連線設定（密碼 AES-256-GCM 加密儲存）
// Patisco 連線設定
// 支援兩種模式：
//   1. 帳密模式：存 username + encryptedPass，cron 定時重新登入
//   2. Token 模式：直接貼上 JWT + apiKey（JWT 到期後需手動重貼）
model SYS_PatiscoConfig {
  id             Int      @id @default(autoincrement())
  mcpUrl         String   @default("https://mcp.patisco.com")

  // 模式 1：帳密（選填，有填才能自動 refresh JWT）
  username       String?
  encryptedPass  String?  // AES-256-GCM 加密

  // 模式 2：直接貼 Token（選填，JWT 到期需手動更新）
  encryptedJwt   String?  // AES-256-GCM 加密，JWT 有時效
  apiKey         String?  // Patisco API Key（長效，UUID 格式）
  userId         String?  // Patisco userId（供顯示用）
  jwtExpiresAt   DateTime? // JWT 到期時間（若能解析）

  webhookSecret  String?  // Webhook 簽名驗證密鑰（選用）
  cronSecret     String?  // Cron 安全驗證密鑰（選用）
  isActive       Boolean  @default(true)
  lastTestedAt   DateTime?
  lastTestStatus String?  // 'ok' | 'error'
  lastTestMsg    String?
  updatedAt      DateTime @updatedAt

  @@map("SYS_PatiscoConfig")
}

// Patisco PI 同步紀錄（去重 + 稽核）
// source: 'webhook' | 'cron'
// status: 'ok' | 'partial' | 'skipped' | 'error'
model SYS_PatiscoSync {
  id           Int      @id @default(autoincrement())
  patiscoDocId Int      @unique  // Patisco PI ID，確保每張 PI 只處理一次
  patiscoDocNo String            // Patisco PI 單號（人讀用）
  syncedAt     DateTime @default(now())
  source       String            // 觸發來源：webhook | cron
  status       String            // 結果：ok | partial | skipped | error
  result       Json?             // 處理細節（哪些商品扣了多少）
  errorMsg     String?           // 錯誤訊息

  @@index([syncedAt])
  @@map("SYS_PatiscoSync")
}

model SYS_User {
  id          Int    @id @default(autoincrement())
  name        String
  loginId     String    @unique
  password    String
  isEnabled   Boolean   @default(true)
  language    String    @default("zh-TW")
  createdAt   DateTime  @default(now())

  // AI 功能：使用者自備 API Key，消耗自己的 token
  aiProvider      String?   // 'claude' | 'openai'
  encryptedAiKey  String?   // AES-256-GCM 加密後的 API Key

  purchaseOrders  PO_Order[]
  costSheets      COST_Sheet[]
  passwordResets  SYS_PasswordReset[]

  @@map("SYS_User")
}

// 公司基本資料（單筆，id=1）
model SYS_Company {
  id            Int      @id @default(autoincrement())

  // 名稱（多語言）
  nameZh        String   @default("")   // 繁體中文公司名稱
  nameEn        String   @default("")   // 英文公司名稱
  shortName     String   @default("")   // 簡稱（文件用）

  // 地址（多語言）
  addressZh     String   @default("")
  addressEn     String   @default("")
  city          String   @default("")
  countryCode   String   @default("TW")

  // 聯絡
  phone         String   @default("")
  fax           String   @default("")
  email         String   @default("")
  website       String   @default("")

  // 貿易身分
  taxId         String   @default("")   // 統一編號 / VAT
  bankName      String   @default("")
  bankAccount   String   @default("")
  bankSwift     String   @default("")

  // 自訂欄位（JSON 陣列：[{ label: string, value: string }]）
  customFields  Json     @default("[]")

  // Logo（base64 data URL，列印時嵌入）
  logoBase64    String?  @db.Text

  updatedAt     DateTime @updatedAt

  @@map("SYS_Company")
}

// Email 寄信設定（用戶自備 Resend API Key，消耗自己的額度）
model SYS_EmailConfig {
  id              Int      @id @default(autoincrement())
  provider        String   @default("resend")  // 目前只支援 resend
  encryptedApiKey String?  // AES-256-GCM 加密
  fromEmail       String   @default("")         // 例：no-reply@yourdomain.com
  fromName        String   @default("")         // 例：Point Asia
  isActive        Boolean  @default(true)
  lastTestedAt    DateTime?
  lastTestStatus  String?  // 'ok' | 'error'
  lastTestMsg     String?
  updatedAt       DateTime @updatedAt

  @@map("SYS_EmailConfig")
}

model SYS_PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      SYS_User @relation(fields: [userId], references: [id])

  @@map("SYS_PasswordReset")
}

model SYS_Currency {
  code        String    @id // USD, TWD, EUR, JPY...
  name        String   
  symbol      String   
  exchangeRate Decimal // 對 TWD 的匯率
  updatedAt   DateTime  @updatedAt

  @@map("SYS_Currency")
}

// =============================================================================
// 商品管理 (PRD_)
// =============================================================================

model PRD_Product {
  id            Int    @id @default(autoincrement())
  name          String   
  sku           String?   @unique
  modelNo       String?  
  description   String?  
  specification String?  

  // 包裝規格
  unitPerInner  Int?     // 每內箱數量
  unitPerCarton Int?     // 每外箱數量
  cbm           Decimal? // 材積 (cubic meter)
  grossWeight   Decimal? // 毛重 KGS
  netWeight     Decimal? // 淨重 KGS
  length        Decimal? // CM
  width         Decimal? 
  height        Decimal? 

  // 貿易資訊
  htsCode       String?  // HTS / HS 海關編碼
  countryOfOrigin String?// ISO 國碼
  unit          String?  // PCS, SET, KGS...

  // 庫存行為
  isMadeToOrder Boolean  @default(false) // true = 可接單無現貨（接單後才採購）
  safetyStock   Int      @default(0)     // 安全庫存量（低於此值發出警告）

  // Patisco 介接
  patiscoProductId Int?  // 對應 Patisco PRD_Product.ID

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  supplierProducts  SUP_SupplierProduct[]
  inventoryItems    INV_Stock[]
  purchaseItems     PO_Item[]
  costSheets        COST_Sheet[]
  categories        PRD_CategoryMapping[]

  @@index([sku])
  @@index([modelNo])
  @@map("PRD_Product")
}

model PRD_Category {
  id        Int   @id @default(autoincrement())
  name      String  
  parentId  Int? 
  parent    PRD_Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  PRD_Category[] @relation("CategoryTree")
  products  PRD_CategoryMapping[]

  @@map("PRD_Category")
}

model PRD_CategoryMapping {
  productId   Int 
  categoryId  Int 
  product     PRD_Product  @relation(fields: [productId], references: [id])
  category    PRD_Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
  @@map("PRD_CategoryMapping")
}

// =============================================================================
// 供應商管理 (SUP_)
// =============================================================================

model SUP_Supplier {
  id            Int    @id @default(autoincrement())
  name          String   
  shortName     String?  
  address       String?  
  city          String?  
  countryCode   String?  
  postalCode    String?  
  phoneNo       String?  
  fax           String?  
  email         String?  
  contactPerson String?  
  taxId         String?  
  paymentTerms  String?  // e.g. "T/T 30 days"
  currencyCode  String?  // 慣用幣別
  note          String?  
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products      SUP_SupplierProduct[]
  purchaseOrders PO_Order[]
  contacts      SUP_Contact[]

  @@index([name])
  @@map("SUP_Supplier")
}

model SUP_Contact {
  id          Int   @id @default(autoincrement())
  supplierId  Int  
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])
  name        String  
  title       String? 
  phoneNo     String? 
  mobile      String? 
  email       String? 
  isDefault   Boolean  @default(false)

  @@index([supplierId])
  @@map("SUP_Contact")
}

model SUP_SupplierProduct {
  id          Int    @id @default(autoincrement())
  supplierId  Int   
  productId   Int   
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])
  product     PRD_Product  @relation(fields: [productId], references: [id])

  supplierSku   String?  // 供應商自己的料號
  unitPrice     Decimal? 
  currencyCode  String?  
  moq           Int?     // 最小起訂量
  leadTimeDays  Int?     
  isPreferred   Boolean   @default(false)  // 主要供應商
  note          String?  
  updatedAt     DateTime  @updatedAt

  @@unique([supplierId, productId])
  @@index([productId])
  @@map("SUP_SupplierProduct")
}

// =============================================================================
// 採購單 (PO_)
// =============================================================================

// 採購狀態
// 0=草稿, 1=已送出, 2=部分到貨, 3=完成, 4=取消
model PO_Order {
  id            Int    @id @default(autoincrement())
  poNo          String    @unique // 採購單號，自動產生
  supplierId    Int   
  supplier      SUP_Supplier @relation(fields: [supplierId], references: [id])

  status        Int       @default(0)
  currencyCode  String   
  exchangeRate  Decimal  // 當時匯率快照
  totalAmount   Decimal? 

  expectedDate  DateTime?// 預計到貨日
  shippedDate   DateTime?// 實際出貨日
  arrivedDate   DateTime?// 實際到貨日

  port          String?  // 裝運港
  shipVia       String?  // 運送方式
  note          String?

  // 採購觸發來源
  // 0 = 主動補貨（預測/季節/促銷）
  // 1 = 接單後採購（isMadeToOrder=true，無現貨接單）
  // 2 = 安全庫存觸發（INV_Stock.quantity < safetyStock）
  sourceType      Int      @default(0)

  // Patisco 溯源（sourceType=1 時填入）
  patiscoOrderNo  String?  // Patisco ORD_Order.No
  patiscoOrderId  Int?     // Patisco ORD_Order.ID

  createdBy     Int
  creator       SYS_User  @relation(fields: [createdBy], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         PO_Item[]
  receipts      PO_Receipt[]

  @@index([supplierId, status])
  @@index([poNo])
  @@map("PO_Order")
}

model PO_Item {
  id          Int    @id @default(autoincrement())
  orderId     Int   
  order       PO_Order  @relation(fields: [orderId], references: [id])
  productId   Int   
  product     PRD_Product @relation(fields: [productId], references: [id])

  unitPrice   Decimal  
  quantity    Int      
  receivedQty Int       @default(0)// 已入庫數量
  unit        String?  
  note        String?  

  receiptItems PO_ReceiptItem[]

  @@index([orderId])
  @@index([productId])
  @@map("PO_Item")
}

model PO_Receipt {
  id          Int    @id @default(autoincrement())
  orderId     Int   
  order       PO_Order  @relation(fields: [orderId], references: [id])
  receiptNo   String   
  receivedAt  DateTime  @default(now())
  note        String?  

  items       PO_ReceiptItem[]
  stockMovements INV_Movement[]

  @@index([orderId])
  @@map("PO_Receipt")
}

model PO_ReceiptItem {
  id          Int     @id @default(autoincrement())
  receiptId   Int    
  receipt     PO_Receipt @relation(fields: [receiptId], references: [id])
  poItemId    Int    
  poItem      PO_Item    @relation(fields: [poItemId], references: [id])
  quantity    Int       

  @@index([receiptId])
  @@map("PO_ReceiptItem")
}

// =============================================================================
// 庫存管理 (INV_)
// =============================================================================
//
// 兩階段庫存模型：
//   quantity     = 實際庫存（倉庫裡真正有的數量）
//   reservedQty  = 預留量（已發 PI 正本給客戶、尚未出倉）
//   availableQty = quantity - reservedQty（前端防超賣用這個數字）
//
// 四個觸發點：
//   入庫：收到供應商 PI 副本確認       → quantity++
//   預留：發出 PI 正本給客戶確認       → reservedQty++
//   取消：PI 正本取消                 → reservedQty--
//   出倉：發出裝箱單+商業發票確認      → quantity--, reservedQty--

model INV_Stock {
  id           Int    @id @default(autoincrement())
  productId    Int    @unique
  product      PRD_Product @relation(fields: [productId], references: [id])

  quantity     Int    @default(0) // 實際庫存（含已預留）
  reservedQty  Int    @default(0) // 已發 PI 正本預留量
  safetyStock  Int    @default(0) // 安全庫存預警值
  avgUnitCost  Decimal? @default(0) // 移動加權平均成本（TWD）
  updatedAt    DateTime @updatedAt

  // availableQty = quantity - reservedQty（在 application layer 計算，不存 DB）

  @@map("INV_Stock")
}

// 異動類型：
//   1 = 入庫      供應商 PI 副本確認（quantity++）
//   2 = 預留      客戶 PI 正本發出（reservedQty++）
//   3 = 取消預留  客戶 PI 正本取消（reservedQty--）
//   4 = 出倉      裝箱單+商業發票發出（quantity--, reservedQty--）
//   5 = 手動調整入
//   6 = 手動調整出
//   7 = 盤點調整
model INV_Movement {
  id           Int      @id @default(autoincrement())
  productId    Int
  type         Int      // 見上方說明

  // 數量變動（正數=增加, 負數=減少）
  qtyDelta        Int   // quantity 的變動量
  reservedDelta   Int   @default(0) // reservedQty 的變動量

  // 異動後快照（方便查帳，不需要重算）
  quantityAfter   Int
  reservedAfter   Int
  avgUnitCostAfter Decimal? // 異動後的移動加權平均成本

  // 來源溯源（對應 Patisco 文件）
  // patiscoDocType: PI_CONFIRMED, PI_CANCELLED, DELIVERY_ORDER, MANUAL
  patiscoDocType  String?
  patiscoDocId    Int?    // Patisco 單據 ID
  patiscoDocNo    String? // Patisco 單據號碼（人讀用）

  // 來源溯源（對應 PAXIS 內部）
  receiptId       Int?
  receipt         PO_Receipt? @relation(fields: [receiptId], references: [id])

  note         String?
  createdAt    DateTime @default(now())

  @@index([productId, createdAt])
  @@index([receiptId])
  @@index([patiscoDocType, patiscoDocId])
  @@map("INV_Movement")
}

// =============================================================================
// 成本計算 (COST_)
// 對應 ET61 的 K-MART / WAL-MART 到岸成本計算表
// =============================================================================

model COST_Sheet {
  id            Int    @id @default(autoincrement())
  name          String   // 試算表名稱
  productId     Int   
  product       PRD_Product @relation(fields: [productId], references: [id])

  // FOB 成本
  fobPrice      Decimal  
  fobCurrency   String   
  fobExRate     Decimal  // FOB 幣別對 USD 匯率快照

  // 出口端
  countryOfOrigin String?
  portOfLoading   String?

  // 進口端成本（USD）
  htsCode         String?
  dutyRate        Decimal?// 關稅率 %
  dutyAmount      Decimal?
  oceanFreight    Decimal?
  insurance       Decimal?
  agentFee        Decimal?
  consolidation   Decimal?
  deconsolidation Decimal?
  userFee         Decimal?
  harborFee       Decimal?
  otherCharge     Decimal?
  otherChargeNote String? 

  // 計算結果
  landedCost    Decimal? // 到岸總成本
  sellingPrice  Decimal? // 建議售價
  grossMarginPct Decimal?// 毛利率 %

  // 容器資訊
  container40ftQty  Int? // 40呎貨櫃裝載量（箱）
  container40ftPcs  Int? // 40呎貨櫃裝載量（件）

  createdBy     Int   
  creator       SYS_User  @relation(fields: [createdBy], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([productId])
  @@map("COST_Sheet")
}
