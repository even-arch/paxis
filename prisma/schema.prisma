// PAXIS — Point Asia eXchange & Inventory System
// Prisma Schema
// 單租戶設計，不需要 TenantID

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 系統設定 (SYS_)
// =============================================================================

model SYS_PatiscoConfig {
  id             Int      @id @default(autoincrement())
  mcpUrl         String   @default("https://mcp.patisco.com")

  // 模式 1：帳密（選填，有填才能自動 refresh JWT）
  username       String?
  encryptedPass  String?  // AES-256-GCM 加密

  // 模式 2：直接貼 Token（選填，JWT 到期需手動更新）
  encryptedJwt   String?  // AES-256-GCM 加密，JWT 有時效
  apiKey         String?  // Patisco API Key（長效，UUID 格式）
  userId         String?  // Patisco userId（供顯示用）
  jwtExpiresAt   DateTime?

  webhookSecret  String?  // Webhook HMAC 簽名驗證密鑰
  cronSecret     String?  // Cron 安全驗證密鑰
  isActive       Boolean  @default(true)
  lastTestedAt   DateTime?
  lastTestStatus String?  // 'ok' | 'error'
  lastTestMsg    String?
  updatedAt      DateTime @updatedAt

  @@map("SYS_PatiscoConfig")
}

// Patisco 同步紀錄（去重 + 稽核）
// source: 'webhook' | 'cron'
// status: 'ok' | 'partial' | 'skipped' | 'error'
model SYS_PatiscoSync {
  id           Int      @id @default(autoincrement())
  docType      String   @default("PI")  // PI | SHIPMENT
  patiscoDocId String
  patiscoDocNo String
  syncedAt     DateTime @default(now())
  source       String   // webhook | cron | manual
  status       String   // ok | partial | skipped | error
  result       Json?
  errorMsg     String?

  @@unique([docType, patiscoDocId])
  @@index([syncedAt])
  @@map("SYS_PatiscoSync")
}

model SYS_User {
  id          Int    @id @default(autoincrement())
  name        String
  loginId     String    @unique
  password    String
  isEnabled   Boolean   @default(true)
  language    String    @default("zh-TW")
  createdAt   DateTime  @default(now())

  aiProvider      String?
  encryptedAiKey  String?
  aiParseModel    String?

  // Relations
  purchaseOrders   PO_Order[]
  receipts         PO_Receipt[]
  supplierPIs      PO_SupplierPI[]
  costSheets       COST_Sheet[]
  passwordResets   SYS_PasswordReset[]
  settingAuditLogs SYS_SettingAuditLog[]
  productHistories PRD_ProductHistory[]
  salesOrders          SLS_Order[]  @relation("SLS_Order_creator")
  salesOrdersPerformed SLS_Order[]  @relation("SLS_Order_performer")
  salesPIs             SLS_PI[]
  shipments        SLS_Shipment[]
  stockMovements   INV_Movement[]

  @@map("SYS_User")
}

model SYS_SettingAuditLog {
  id          Int      @id @default(autoincrement())
  field       String
  oldValue    String?
  newValue    String?
  reason      String?  @db.Text
  changedBy   Int
  changer     SYS_User @relation(fields: [changedBy], references: [id])
  changedAt   DateTime @default(now())

  @@index([field, changedAt])
  @@map("SYS_SettingAuditLog")
}

model SYS_Company {
  id            Int      @id @default(autoincrement())

  // WAC = 加權平均成本, FIFO = 先進先出, LIFO = 後進先出, SPECIFIC = 個別辨識
  // 變更時必須寫入 SYS_SettingAuditLog
  inventoryMethod String @default("WAC")

  nameZh        String   @default("")
  nameEn        String   @default("")
  shortName     String   @default("")
  addressZh     String   @default("")
  addressEn     String   @default("")
  city          String   @default("")
  countryCode   String   @default("TW")
  phone         String   @default("")
  fax           String   @default("")
  email         String   @default("")
  website       String   @default("")
  taxId         String   @default("")
  bankName      String   @default("")
  bankAccount   String   @default("")
  bankSwift     String   @default("")
  customFields  Json     @default("[]")
  logoBase64    String?  @db.Text
  updatedAt     DateTime @updatedAt

  @@map("SYS_Company")
}

model SYS_EmailConfig {
  id              Int      @id @default(autoincrement())
  provider        String   @default("resend")
  encryptedApiKey String?
  fromEmail       String   @default("")
  fromName        String   @default("")
  isActive        Boolean  @default(true)
  lastTestedAt    DateTime?
  lastTestStatus  String?
  lastTestMsg     String?
  updatedAt       DateTime @updatedAt

  @@map("SYS_EmailConfig")
}

model SYS_PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      SYS_User @relation(fields: [userId], references: [id])

  @@map("SYS_PasswordReset")
}

model SYS_Currency {
  code         String   @id
  name         String
  symbol       String
  exchangeRate Decimal
  updatedAt    DateTime @updatedAt

  @@map("SYS_Currency")
}

// 交易條件價格換算規則（公司級設定）
// 例：供應商報 FOR（14）→ 我方對外 FOB（13）→ 需減 2.5%
// adjustmentPct 正值 = 加 %；負值 = 減 %
model SYS_PriceAdjustRule {
  id            Int     @id @default(autoincrement())
  fromTerms     Int     // 進貨條件 Patisco code（14=FOR, 13=FOB…）
  toTerms       Int     // 對外條件 Patisco code（通常 13=FOB）
  adjustmentPct Decimal // e.g. -2.50 = 减 2.5%；+5.00 = 加 5%
  note          String?
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([fromTerms, toTerms])
  @@map("SYS_PriceAdjustRule")
}

// =============================================================================
// 商品管理 (PRD_)
// =============================================================================

model PRD_Product {
  id            Int    @id @default(autoincrement())
  name          String
  sku           String?   @unique
  modelNo       String?
  description   String?
  specification String?

  unitPerInner  Int?
  unitPerCarton Int?
  cbm           Decimal?
  grossWeight   Decimal?
  netWeight     Decimal?
  length        Decimal?
  width         Decimal?
  height        Decimal?

  htsCode         String?
  countryOfOrigin String?
  unit            String?

  isMadeToOrder Boolean  @default(false)
  safetyStock   Int      @default(0)

  patiscoProductId String?

  sellingPrice      Decimal?
  isAvailableForPos Boolean  @default(false)
  posProductId      String?

  isActive      Boolean   @default(true)
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  supplierProducts  SUP_SupplierProduct[]
  inventoryItems    INV_Stock[]
  purchaseItems     PO_Item[]
  salesItems        SLS_Item[]
  costSheets        COST_Sheet[]
  categories        PRD_CategoryMapping[]
  history           PRD_ProductHistory[]

  @@index([sku])
  @@index([modelNo])
  @@map("PRD_Product")
}

model PRD_ProductHistory {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     PRD_Product @relation(fields: [productId], references: [id])

  name          String
  sku           String?
  modelNo       String?
  specification String?
  unitPerInner  Int?
  unitPerCarton Int?
  cbm           Decimal?
  grossWeight   Decimal?
  netWeight     Decimal?
  unit          String?
  unitCost      Decimal?
  currency      String?

  // PO_RECEIPT | AI_IMPORT | MANUAL_EDIT
  sourceType  String
  poOrderId   Int?
  poOrderNo   String?

  changedBy   Int
  changer     SYS_User @relation(fields: [changedBy], references: [id])
  createdAt   DateTime @default(now())

  @@index([productId, createdAt])
  @@map("PRD_ProductHistory")
}

model PRD_Category {
  id        Int   @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    PRD_Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  PRD_Category[] @relation("CategoryTree")
  products  PRD_CategoryMapping[]

  @@map("PRD_Category")
}

model PRD_CategoryMapping {
  productId   Int
  categoryId  Int
  product     PRD_Product  @relation(fields: [productId], references: [id])
  category    PRD_Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
  @@map("PRD_CategoryMapping")
}

// =============================================================================
// 供應商管理 (SUP_)
// =============================================================================

model SUP_Supplier {
  id            Int    @id @default(autoincrement())
  name          String
  shortName     String?
  address       String?
  city          String?
  countryCode   String?
  postalCode    String?
  phoneNo       String?
  fax           String?
  email         String?
  contactPerson String?
  taxId         String?
  paymentTerms  String?
  currencyCode  String?
  note          String?

  patiscoSupplierId String?  // 對應 Patisco 供應商 ID（未來開放時使用）

  // 交易條件（Patisco Fix_Var TradingTerm code：13=FOB, 14=FOR, 2=CIF…）
  defaultTradeTerms Int?

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 付款週期（天數，null 表示未設定）
  paymentCycleDays Int?

  products       SUP_SupplierProduct[]
  purchaseOrders PO_Order[]
  contacts       SUP_Contact[]
  payables       FIN_Payable[]

  @@index([name])
  @@map("SUP_Supplier")
}

model SUP_Contact {
  id          Int   @id @default(autoincrement())
  supplierId  Int
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])
  name        String
  title       String?
  phoneNo     String?
  mobile      String?
  email       String?
  isDefault   Boolean  @default(false)

  @@index([supplierId])
  @@map("SUP_Contact")
}

model SUP_SupplierProduct {
  id          Int    @id @default(autoincrement())
  supplierId  Int
  productId   Int
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])
  product     PRD_Product  @relation(fields: [productId], references: [id])

  supplierSku   String?
  unitPrice     Decimal?
  currencyCode  String?
  moq           Int?
  leadTimeDays  Int?
  isPreferred   Boolean   @default(false)
  note          String?
  updatedAt     DateTime  @updatedAt

  @@unique([supplierId, productId])
  @@index([productId])
  @@map("SUP_SupplierProduct")
}

// =============================================================================
// 客戶管理 (CUS_)
// PAXIS 的客戶主檔，不直接對應 Patisco BU_Buyer。
// Patisco webhook 帶來的 buyerCompanyId 存在 SLS_Order.patiscoBuyerId，
// 由人工或自動流程關聯到此主檔。
// =============================================================================

model CUS_Customer {
  id            Int    @id @default(autoincrement())
  name          String
  shortName     String?
  address       String?
  city          String?
  countryCode   String?
  postalCode    String?
  phoneNo       String?
  fax           String?
  email         String?
  contactPerson String?
  taxId         String?
  paymentTerms  String?
  currencyCode  String?
  note          String?

  patiscoBuyerId String?   // 對應 Patisco BS_Company.ID（選填，人工關聯）

  // 交易條件（Patisco Fix_Var TradingTerm code：13=FOB, 14=FOR, 2=CIF…）
  defaultTradeTerms Int?

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 收款週期（天數，null 表示未設定）
  collectionCycleDays Int?

  salesOrders   SLS_Order[]
  contacts      CUS_Contact[]
  receivables   FIN_Receivable[]

  @@index([name])
  @@map("CUS_Customer")
}

model CUS_Contact {
  id          Int   @id @default(autoincrement())
  customerId  Int
  customer    CUS_Customer @relation(fields: [customerId], references: [id])
  name        String
  title       String?
  phoneNo     String?
  mobile      String?
  email       String?
  isDefault   Boolean  @default(false)

  @@index([customerId])
  @@map("CUS_Contact")
}

// =============================================================================
// 採購單 (PO_)
//
// 採購流程三節點：
//   節點 1：PO_Order      — 我發出訂單正本給供應商（庫存不動）
//   節點 2：PO_SupplierPI — 收到供應商 PI 副本，確認預計出貨（庫存不動）
//   節點 3：PO_Receipt    — 收到裝箱單/實際到貨，按「入庫」→ quantity++
//
// 注意：quantity++ 發生在節點 3（裝箱單），不是節點 2（PI 副本）。
// =============================================================================

// 採購單狀態
// 0=草稿, 1=已送出, 2=部分到貨, 3=完成, 4=取消
model PO_Order {
  id            Int    @id @default(autoincrement())
  poNo          String    @unique
  supplierId    Int
  supplier      SUP_Supplier @relation(fields: [supplierId], references: [id])

  // ── 交易鏈關聯（核心勾稽欄位）──────────────────────────────────────────
  // 這張採購單是為了哪張客戶銷售訂單而發出的？
  // sourceType=1（接單後採購）時必填；sourceType=0（主動補貨）時為 null。
  // 一張 SLS_Order 可以對應多張 PO_Order（拆單給不同供應商時，
  // poNo 會加上後綴：ABC-2025-001-1、ABC-2025-001-2…）
  salesOrderId  Int?
  salesOrder    SLS_Order? @relation("SLS_PO_OrderLink", fields: [salesOrderId], references: [id])

  status        Int       @default(0)
  currencyCode  String
  exchangeRate  Decimal
  totalAmount   Decimal?

  expectedDate  DateTime? // 預計到貨日
  shippedDate   DateTime? // 供應商實際出貨日（從裝箱單取得）
  arrivedDate   DateTime? // 實際到貨日

  port          String?
  shipVia       String?
  note          String?

  // 採購觸發來源
  // 0 = 主動補貨, 1 = 接單後採購（isMadeToOrder）, 2 = 安全庫存觸發
  sourceType      Int      @default(0)

  patiscoOrderNo  String?
  patiscoOrderId  String?

  createdBy     Int
  creator       SYS_User  @relation(fields: [createdBy], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         PO_Item[]
  supplierPIs   PO_SupplierPI[]
  receipts      PO_Receipt[]

  @@index([supplierId, status])
  @@index([poNo])
  @@index([salesOrderId])
  @@map("PO_Order")
}

model PO_Item {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       PO_Order  @relation(fields: [orderId], references: [id])
  productId   Int
  product     PRD_Product @relation(fields: [productId], references: [id])

  unitPrice   Decimal
  quantity    Int
  receivedQty Int       @default(0)
  unit        String?
  note        String?

  receiptItems    PO_ReceiptItem[]
  supplierPIItems PO_SupplierPIItem[]

  @@index([orderId])
  @@index([productId])
  @@map("PO_Item")
}

// 節點 2：收到供應商 PI 副本
// 記錄供應商確認的數量與預計出貨日，庫存不動。
model PO_SupplierPI {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       PO_Order  @relation(fields: [orderId], references: [id])
  piNo        String    // 供應商的 PI 單號

  estimatedShipDate DateTime? // 供應商 PI 上標註的預計出貨日
  note        String?

  // 交易條件 & PI 層級加收
  tradeTermsCode Int?    // Patisco payment 欄位值（13=FOB, 14=FOR…）
  extraCharges   Json?   // [{name, type, amount}]

  // 操作稽核
  // source: PATISCO | MANUAL | AI_IMPORT
  source      String   @default("MANUAL")
  performedBy Int?     // null = Patisco 自動觸發
  performer   SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  patiscoDocId     String?
  patiscoDocNo     String?
  patiscoCreatedAt DateTime? // Patisco 原始建立時間（createdDate YYYYMMDDHHmmss）

  items       PO_SupplierPIItem[]

  @@index([orderId])
  @@map("PO_SupplierPI")
}

model PO_SupplierPIItem {
  id            Int    @id @default(autoincrement())
  supplierPIId  Int
  supplierPI    PO_SupplierPI @relation(fields: [supplierPIId], references: [id])
  poItemId      Int
  poItem        PO_Item       @relation(fields: [poItemId], references: [id])

  confirmedQty  Int  // 供應商確認的出貨數量

  @@index([supplierPIId])
  @@map("PO_SupplierPIItem")
}

// 節點 3：入庫確認（收到裝箱單 or 直接按入庫）
// 觸發 quantity++，寫 INV_Movement type=1
model PO_Receipt {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       PO_Order  @relation(fields: [orderId], references: [id])
  receiptNo   String

  // 操作稽核（必填，記錄是誰在什麼時間按下入庫）
  // source: PATISCO | MANUAL | AI_IMPORT
  source      String   @default("MANUAL")
  performedBy Int?     // null = Patisco 自動觸發
  performer   SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  patiscoDocId  String?
  patiscoDocNo  String?

  note        String?

  items          PO_ReceiptItem[]
  stockMovements INV_Movement[]
  payable        FIN_Payable?

  @@index([orderId])
  @@map("PO_Receipt")
}

model PO_ReceiptItem {
  id          Int     @id @default(autoincrement())
  receiptId   Int
  receipt     PO_Receipt @relation(fields: [receiptId], references: [id])
  poItemId    Int
  poItem      PO_Item    @relation(fields: [poItemId], references: [id])
  quantity    Int

  @@index([receiptId])
  @@map("PO_ReceiptItem")
}

// =============================================================================
// 銷售單 (SLS_)
//
// 銷售流程三節點：
//   節點 1：SLS_Order    — 收到客戶訂單（庫存不動）
//   節點 2：SLS_PI       — 我發出 PI 正本給客戶 → reservedQty++
//   節點 3：SLS_Shipment — 發出裝箱單/確認出貨 → quantity--, reservedQty--
//
// 三種來源：
//   PATISCO   = Patisco webhook 自動建立
//   MANUAL    = 人工手填
//   AI_IMPORT = 上傳 PDF/Excel，AI 解析後人工確認
// =============================================================================

// 銷售訂單狀態
// 0=草稿, 1=已確認, 2=PI已發出, 3=部分出貨, 4=完成, 5=取消
model SLS_Order {
  id          Int    @id @default(autoincrement())
  orderNo     String    @unique
  customerId  Int?   // 可能尚未比對到客戶主檔
  customer    CUS_Customer? @relation(fields: [customerId], references: [id])

  status      Int    @default(0)
  currencyCode  String
  exchangeRate  Decimal
  totalAmount   Decimal?

  // 客戶期望出貨日（可能為 null，訂單上不一定有）
  customerRequestedShipDate DateTime?
  note        String?

  // 操作稽核
  source      String   @default("MANUAL")
  performedBy Int?
  performer   SYS_User? @relation("SLS_Order_performer", fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  // Patisco 溯源
  patiscoBuyerId  String?    // Patisco buyerCompanyId（webhook 帶來）
  patiscoBuyerName String? // 買家公司名稱快照
  patiscoDocId    String?
  patiscoDocNo    String?
  patiscoCreatedAt DateTime? // Patisco 原始建立時間（createdDate YYYYMMDDHHmmss）

  createdBy   Int
  creator     SYS_User  @relation("SLS_Order_creator", fields: [createdBy], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items          SLS_Item[]
  pis            SLS_PI[]
  shipments      SLS_Shipment[]
  purchaseOrders PO_Order[]    @relation("SLS_PO_OrderLink") // 此銷售訂單衍生的採購單（可多張）

  @@index([customerId, status])
  @@index([orderNo])
  @@map("SLS_Order")
}

model SLS_Item {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       SLS_Order   @relation(fields: [orderId], references: [id])
  productId   Int
  product     PRD_Product @relation(fields: [productId], references: [id])

  unitPrice   Decimal
  quantity    Int
  shippedQty  Int    @default(0) // 已出貨數量
  unit        String?
  note        String?

  piItems       SLS_PIItem[]
  shipmentItems SLS_ShipmentItem[]

  @@index([orderId])
  @@index([productId])
  @@map("SLS_Item")
}

// 節點 2：我發出 PI 正本給客戶
// 觸發 reservedQty++，寫 INV_Movement type=2
model SLS_PI {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       SLS_Order @relation(fields: [orderId], references: [id])
  piNo        String    @unique

  // PI 上標註的預計出貨日（較貼近實際，用於追蹤提醒）
  estimatedShipDate DateTime?

  // 交易條件（Patisco TradingTerm code：13=FOB, 14=FOR…）& PI 層級加收
  tradeTermsCode Int?    // Patisco payment 欄位值
  extraCharges   Json?   // [{name, type, amount}]，對應 Patisco extraCharges

  // 0=有效, 1=已取消
  status      Int    @default(0)
  cancelledAt DateTime?
  cancelReason String?

  // 操作稽核
  source      String   @default("MANUAL")
  performedBy Int?
  performer   SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  patiscoDocId  String?
  patiscoDocNo  String?
  patiscoCreatedAt DateTime? // Patisco 原始建立時間（createdDate YYYYMMDDHHmmss）

  items       SLS_PIItem[]
  shipments   SLS_Shipment[]
  stockMovements INV_Movement[]

  @@index([orderId])
  @@map("SLS_PI")
}

model SLS_PIItem {
  id          Int    @id @default(autoincrement())
  piId        Int
  pi          SLS_PI    @relation(fields: [piId], references: [id])
  slsItemId   Int
  slsItem     SLS_Item  @relation(fields: [slsItemId], references: [id])

  quantity    Int

  // 品項層級快照（從 Patisco sync 填入，不覆蓋 PRD_Product）
  unitPrice     Decimal?
  unit          String?
  unitPerCarton Int?
  cbm           Decimal?
  grossWeight   Decimal?
  netWeight     Decimal?

  @@index([piId])
  @@map("SLS_PIItem")
}

// 節點 3：出貨確認（發出裝箱單 or 直接按出貨）
// 觸發 quantity--, reservedQty--，寫 INV_Movement type=4
model SLS_Shipment {
  id          Int    @id @default(autoincrement())
  piId        Int?
  pi          SLS_PI?   @relation(fields: [piId], references: [id])
  orderId     Int
  order       SLS_Order @relation(fields: [orderId], references: [id])
  shipmentNo  String    @unique

  // 實際出貨資訊（作為最終 shippedAt 記錄）
  actualShipDate  DateTime
  shippingMethod  String?  // SEA | AIR | COURIER
  portOfLoading   String?  // UN/LOCODE，如 TWKHH
  portOfDischarge String?
  trackingNo      String?

  // 操作稽核（必填）
  source      String   @default("MANUAL")
  performedBy Int?
  performer   SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt DateTime @default(now())

  patiscoDocId  String?
  patiscoDocNo  String?

  note        String?

  items          SLS_ShipmentItem[]
  stockMovements INV_Movement[]
  receivable     FIN_Receivable?

  @@index([orderId])
  @@map("SLS_Shipment")
}

model SLS_ShipmentItem {
  id            Int    @id @default(autoincrement())
  shipmentId    Int
  shipment      SLS_Shipment @relation(fields: [shipmentId], references: [id])
  slsItemId     Int
  slsItem       SLS_Item     @relation(fields: [slsItemId], references: [id])

  quantity      Int

  @@index([shipmentId])
  @@map("SLS_ShipmentItem")
}

// =============================================================================
// 庫存管理 (INV_)
//
// 兩階段庫存模型：
//   quantity     = 實際庫存（倉庫裡真正有的數量）
//   reservedQty  = 預留量（已發 PI 正本給客戶、尚未出倉）
//   availableQty = quantity - reservedQty（前端防超賣用這個，不存 DB）
//
// 五個觸發點（對應文件節點）：
//   入庫：收到裝箱單/按入庫（PO_Receipt）           → quantity++
//   預留：發出 PI 正本給客戶（SLS_PI）              → reservedQty++
//   取消預留：PI 正本取消（SLS_PI.status=1）        → reservedQty--
//   出倉：發出裝箱單/按出貨（SLS_Shipment）         → quantity--, reservedQty--
//   手動調整/盤點/POS                              → 依情況
// =============================================================================

model INV_Stock {
  id           Int    @id @default(autoincrement())
  productId    Int    @unique
  product      PRD_Product @relation(fields: [productId], references: [id])

  quantity     Int    @default(0)
  reservedQty  Int    @default(0)
  safetyStock  Int    @default(0)
  avgUnitCost  Decimal? @default(0)
  updatedAt    DateTime @updatedAt

  @@map("INV_Stock")
}

// 異動類型：
//   1 = 採購入庫   PO_Receipt 確認（quantity++）
//   2 = 預留       SLS_PI 發出（reservedQty++）
//   3 = 取消預留   SLS_PI 取消（reservedQty--）
//   4 = 出倉       SLS_Shipment 確認（quantity--, reservedQty--）
//   5 = 手動調整入
//   6 = 手動調整出
//   7 = 盤點調整
//   8 = POS 銷售出庫（預留給 POS 對接）
//   9 = POS 退貨入庫（預留給 POS 對接）
model INV_Movement {
  id           Int      @id @default(autoincrement())
  productId    Int
  type         Int

  qtyDelta        Int
  reservedDelta   Int   @default(0)

  // 異動後快照（方便查帳，不需要重算）
  quantityAfter    Int
  reservedAfter    Int
  avgUnitCostAfter Decimal?

  // 操作稽核（是誰在什麼時間觸發這筆異動）
  // performedBy = null 時表示 Patisco 自動觸發（稽核資訊在 patiscoDocId）
  performedBy  Int?
  performer    SYS_User? @relation(fields: [performedBy], references: [id])
  performedAt  DateTime  @default(now())

  // 來源溯源（PATISCO | MANUAL | AI_IMPORT）
  source       String    @default("MANUAL")

  // 採購側溯源
  receiptId    Int?
  receipt      PO_Receipt? @relation(fields: [receiptId], references: [id])

  // 銷售側溯源
  slsPiId      Int?
  slsPi        SLS_PI?      @relation(fields: [slsPiId], references: [id])
  slsShipmentId Int?
  slsShipment   SLS_Shipment? @relation(fields: [slsShipmentId], references: [id])

  // Patisco 文件溯源
  patiscoDocType  String?  // ORDER | PI | SHIPMENT
  patiscoDocId    String?
  patiscoDocNo    String?

  note         String?
  createdAt    DateTime @default(now())

  @@index([productId, createdAt])
  @@index([receiptId])
  @@index([slsPiId])
  @@index([slsShipmentId])
  @@index([patiscoDocType, patiscoDocId])
  @@map("INV_Movement")
}

// =============================================================================
// 成本計算 (COST_)
// =============================================================================

model COST_Sheet {
  id            Int    @id @default(autoincrement())
  name          String
  productId     Int
  product       PRD_Product @relation(fields: [productId], references: [id])

  fobPrice      Decimal
  fobCurrency   String
  fobExRate     Decimal

  countryOfOrigin String?
  portOfLoading   String?

  htsCode         String?
  dutyRate        Decimal?
  dutyAmount      Decimal?
  oceanFreight    Decimal?
  insurance       Decimal?
  agentFee        Decimal?
  consolidation   Decimal?
  deconsolidation Decimal?
  userFee         Decimal?
  harborFee       Decimal?
  otherCharge     Decimal?
  otherChargeNote String?

  landedCost      Decimal?
  sellingPrice    Decimal?
  grossMarginPct  Decimal?

  container40ftQty  Int?
  container40ftPcs  Int?

  createdBy     Int
  creator       SYS_User  @relation(fields: [createdBy], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([productId])
  @@map("COST_Sheet")
}

// =============================================================================
// 財務對帳 (FIN_)
//
// FIN_Payable   — 應付帳款，由 PO_Receipt 入庫確認時自動產生
// FIN_Receivable — 應收帳款，由 SLS_Shipment 出貨確認時自動產生
// =============================================================================

// 付款狀態：0=未付, 1=部分付清, 2=已付清
model FIN_Payable {
  id          Int    @id @default(autoincrement())

  supplierId  Int
  supplier    SUP_Supplier @relation(fields: [supplierId], references: [id])

  // 來源單據
  receiptId   Int    @unique
  receipt     PO_Receipt @relation(fields: [receiptId], references: [id])

  // 金額（TWD）
  amountTWD   Decimal

  // 到期日（入庫日 + 供應商付款週期）
  dueDate     DateTime?

  // 付款狀態
  status      Int    @default(0)  // 0=未付, 1=部分, 2=已付
  paidAt      DateTime?
  paidAmountTWD Decimal?
  note        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplierId])
  @@index([dueDate])
  @@map("FIN_Payable")
}

// 收款狀態：0=未收, 1=部分收款, 2=已收清
model FIN_Receivable {
  id          Int    @id @default(autoincrement())

  customerId  Int?
  customer    CUS_Customer? @relation(fields: [customerId], references: [id])
  customerName String?  // 備用，customerId 為 null 時使用

  // 來源單據
  shipmentId  Int    @unique
  shipment    SLS_Shipment @relation(fields: [shipmentId], references: [id])

  // 金額（原始幣別，通常是 EUR）
  currencyCode    String
  amountForeign   Decimal  // EUR 金額

  // 報帳匯率（PI 開出時的匯率，用於帳面計算）
  rateAtInvoice   Decimal
  amountTWD       Decimal  // = amountForeign × rateAtInvoice

  // 到期日（出貨日 + 客戶收款週期）
  dueDate         DateTime?

  // 收款狀態
  status          Int    @default(0)  // 0=未收, 1=部分, 2=已收
  collectedAt     DateTime?
  collectedForeign Decimal?  // 實際收到的 EUR 金額
  rateAtCollection Decimal?  // 押匯匯率
  collectedTWD    Decimal?   // = collectedForeign × rateAtCollection
  fxGainLoss      Decimal?   // = collectedTWD - (collectedForeign × rateAtInvoice)

  note            String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customerId])
  @@index([dueDate])
  @@map("FIN_Receivable")
}

// =============================================================================
// UPS 出貨提單紀錄 (UPS_)
// 記錄每一張 UPS 提單的完整資訊，包含關聯 PI、提貨預約等。
// =============================================================================

model UPS_ShipmentLog {
  id                   Int      @id @default(autoincrement())

  // UPS 回傳識別碼
  trackingNumber       String
  upsShipmentId        String?  // UPS ShipmentIdentificationNumber

  // 服務
  serviceCode          String
  serviceName          String?

  // 關聯 PI（選填，可能是手動建立未關聯 PI）
  piId                 Int?
  piNo                 String?

  // 地址快照（JSON，避免主檔變更後失去歷史紀錄）
  originSnapshot       Json
  destinationSnapshot  Json

  // 貨物快照
  packagesSnapshot     Json     // Array of { weightKg, dims, items[] }
  declaredValue        Decimal?
  declaredCurrency     String?

  // 費用（UPS 回傳）
  chargedAmount        Decimal?
  chargedCurrency      String?

  // 標籤（Base64）
  labelBase64          String?  @db.Text
  labelFormat          String?  @default("GIF")  // GIF | PNG | PDF

  // 預約提貨
  pickupConfirmationNo String?
  pickupReadyTime      DateTime?   // 可供提貨的最早時間
  pickupCloseTime      DateTime?   // 最晚關門時間
  pickupScheduledDate  DateTime?   // UPS 預約提貨日

  createdAt            DateTime @default(now())
  createdByUserId      Int?

  @@index([trackingNumber])
  @@index([piNo])
  @@index([createdAt])
  @@map("UPS_ShipmentLog")
}
